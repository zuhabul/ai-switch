percent_int_or_default() {
  local raw="$1"
  local fallback="${2:-999}"
  local pct
  pct="$(format_percent "${raw}")"
  if [[ -z "${pct}" || ! "${pct}" =~ ^[0-9]+$ ]]; then
    echo "${fallback}"
    return 0
  fi
  echo "${pct}"
}

reset_bias_score() {
  local resets_at="$1"
  local now_epoch="$2"
  local delta
  local hours
  if [[ -z "${resets_at}" || ! "${resets_at}" =~ ^[0-9]+$ ]]; then
    echo "999"
    return 0
  fi
  delta=$((resets_at - now_epoch))
  if (( delta <= 0 )); then
    echo "0"
    return 0
  fi
  hours=$((delta / 3600))
  if (( hours > 999 )); then
    hours=999
  fi
  echo "${hours}"
}

account_rotation_score() {
  local account="$1"
  local now_epoch="$2"
  local primary_used=""
  local secondary_used=""
  local primary_reset=""
  local has_data=1
  local primary_i
  local secondary_i
  local reset_bias
  local score

  primary_used="$(jq -r --arg account "${account}" '.accounts[$account].primary.used_percent // empty' "${CODEX_LIMITS_FILE}")"
  secondary_used="$(jq -r --arg account "${account}" '.accounts[$account].secondary.used_percent // empty' "${CODEX_LIMITS_FILE}")"
  primary_reset="$(jq -r --arg account "${account}" '.accounts[$account].primary.resets_at // empty' "${CODEX_LIMITS_FILE}")"

  if [[ -z "${primary_used}" && -z "${secondary_used}" ]]; then
    has_data=0
  fi

  primary_i="$(percent_int_or_default "${primary_used}" 999)"
  secondary_i="$(percent_int_or_default "${secondary_used}" 999)"
  reset_bias="$(reset_bias_score "${primary_reset}" "${now_epoch}")"
  score=$((secondary_i * 100000 + primary_i * 1000 + reset_bias))

  echo "${score}|${has_data}|${primary_i}|${secondary_i}|${primary_reset}"
}

select_best_ready_account() {
  local now_epoch="$1"
  shift
  local accounts=("$@")
  local account
  local best_account=""
  local best_score=""
  local best_has_data=0
  local cooldown_until=0
  local info
  local score
  local has_data

  for account in "${accounts[@]}"; do
    cooldown_until="$(jq -r --arg account "${account}" '.cooldowns[$account].until_epoch // 0' "${CODEX_POOL_FILE}")"
    if [[ "${cooldown_until}" =~ ^[0-9]+$ ]] && (( cooldown_until > now_epoch )); then
      continue
    fi
    info="$(account_rotation_score "${account}" "${now_epoch}")"
    score="${info%%|*}"
    has_data="$(cut -d'|' -f2 <<< "${info}")"

    if [[ -z "${best_account}" ]]; then
      best_account="${account}"
      best_score="${score}"
      best_has_data="${has_data}"
      continue
    fi

    if (( has_data > best_has_data )); then
      best_account="${account}"
      best_score="${score}"
      best_has_data="${has_data}"
      continue
    fi
    if (( has_data == best_has_data )) && (( score < best_score )); then
      best_account="${account}"
      best_score="${score}"
      best_has_data="${has_data}"
    fi
  done

  [[ -n "${best_account}" ]] || return 1
  echo "${best_account}"
}

