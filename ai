fail() {
  echo "Error: $*" >&2
  exit 1
}

warn() {
  echo "Warning: $*" >&2
}

ensure_deps() {
  command -v jq >/dev/null 2>&1 || fail "jq is required but not installed."
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_dirs() {
  mkdir -p "${STORE_DIR}"
  mkdir -p "${STATE_DIR}"
  mkdir -p "${RUNTIME_DIR}"
  mkdir -p "${CODEX_LOG_DIR}"
}

validate_account_name() {
  local account="$1"
  [[ "${account}" =~ ^[A-Za-z0-9._-]+$ ]] || fail "Invalid account name '${account}'. Allowed: A-Z a-z 0-9 . _ -"
}

validate_platform() {
  local platform="$1"
  case "${platform}" in
    codex|opencode|all) ;;
    *) fail "Invalid platform '${platform}'. Use codex, opencode, or all." ;;
  esac
}

platform_label() {
  case "$1" in
    codex) echo "Codex" ;;
    opencode) echo "OpenCode" ;;
    all) echo "All platforms" ;;
  esac
}

platform_available() {
  case "$1" in
    codex) [[ -f "${CODEX_AUTH_FILE}" ]] ;;
    opencode) [[ -f "${OPENCODE_AUTH_FILE}" ]] ;;
    *) return 1 ;;
  esac
}

ensure_codex_pool_file() {
  if [[ ! -f "${CODEX_POOL_FILE}" ]]; then
    jq -n '{accounts: [], cooldowns: {}, last_account: null, updated_at: null}' > "${CODEX_POOL_FILE}"
    chmod 600 "${CODEX_POOL_FILE}" || true
  fi
}

ensure_codex_limits_file() {
  if [[ ! -f "${CODEX_LIMITS_FILE}" ]]; then
    jq -n '{accounts: {}, updated_at: null}' > "${CODEX_LIMITS_FILE}"
    chmod 600 "${CODEX_LIMITS_FILE}" || true
  fi
}

ensure_codex_session_state_file() {
  if [[ ! -f "${CODEX_SESSION_STATE_FILE}" ]]; then
    jq -n '{
      session_id: null,
      session_file: null,
      cwd: null,
      account: null,
      pending_resume: false,
      last_exit_reason: null,
      updated_at: null
    }' > "${CODEX_SESSION_STATE_FILE}"
    chmod 600 "${CODEX_SESSION_STATE_FILE}" || true
  fi
}

list_session_files_newest() {
  find "${CODEX_HOME}/sessions" -type f -name '*.jsonl' -printf '%T@ %p\n' 2>/dev/null \
    | sort -nr \
    | cut -d' ' -f2-
}

normalize_path() {
  local value="$1"
  if [[ -z "${value}" ]]; then
    return 1
  fi
  readlink -f -- "${value}" 2>/dev/null || printf '%s\n' "${value}"
}

session_file_cwd() {
  local file="$1"
  [[ -f "${file}" ]] || return 1
  jq -r 'select(.type == "session_meta") | .payload.cwd // empty' "${file}" | head -n 1
}

session_file_matches_cwd() {
  local file="$1"
  local cwd_filter="$2"
  local session_cwd=""
  local normalized_file_cwd=""
  local normalized_filter=""

  [[ -n "${cwd_filter}" && -f "${file}" ]] || return 1
  session_cwd="$(session_file_cwd "${file}" || true)"
  [[ -n "${session_cwd}" ]] || return 1

  if [[ "${session_cwd}" == "${cwd_filter}" ]]; then
    return 0
  fi

  normalized_file_cwd="$(normalize_path "${session_cwd}" || true)"
  normalized_filter="$(normalize_path "${cwd_filter}" || true)"
  [[ -n "${normalized_file_cwd}" && -n "${normalized_filter}" && "${normalized_file_cwd}" == "${normalized_filter}" ]]
}

has_tty_color() {
  [[ -t 1 ]] || return 1
  [[ "${TERM:-}" != "dumb" ]] || return 1
  return 0
}

colorize() {
  local code="$1"
  local text="$2"
  if has_tty_color; then
    printf '\033[%sm%s\033[0m' "${code}" "${text}"
  else
    printf '%s' "${text}"
  fi
}

format_epoch_utc() {
  local epoch="$1"
  if [[ -z "${epoch}" || ! "${epoch}" =~ ^[0-9]+$ || "${epoch}" -le 0 ]]; then
    echo "unknown"
    return 0
  fi
  date -u -d "@${epoch}" '+%Y-%m-%d %H:%M UTC'
}

iso_to_epoch() {
  local iso="$1"
  if [[ -z "${iso}" || "${iso}" == "null" ]]; then
    echo ""
    return 0
  fi
  date -d "${iso}" +%s 2>/dev/null || true
}

format_duration() {
  local total_seconds="$1"
  local days
  local hours
  local minutes
  local seconds
  local parts=()

  if [[ -z "${total_seconds}" || ! "${total_seconds}" =~ ^-?[0-9]+$ ]]; then
    echo "unknown"
    return 0
  fi

  if (( total_seconds <= 0 )); then
    echo "now"
    return 0
  fi

  days=$((total_seconds / 86400))
  hours=$(((total_seconds % 86400) / 3600))
  minutes=$(((total_seconds % 3600) / 60))
  seconds=$((total_seconds % 60))

  if (( days > 0 )); then
    parts+=("${days}d")
  fi
  if (( hours > 0 )); then
    parts+=("${hours}h")
  fi
  if (( minutes > 0 )); then
    parts+=("${minutes}m")
  fi
  if (( ${#parts[@]} == 0 )); then
    parts+=("${seconds}s")
  fi

  printf '%s' "${parts[0]}"
  if [[ "${#parts[@]}" -gt 1 ]]; then
    printf ' %s' "${parts[1]}"
  fi
}

format_percent() {
  local value="$1"
  if [[ -z "${value}" || "${value}" == "null" ]]; then
    echo "?"
    return 0
  fi
  printf '%.0f' "${value}"
}

percent_bar() {
  local percent="$1"
  local width="${2:-20}"
  local filled=0
  local empty=0
  local bar=""
  local i

  if [[ -z "${percent}" || ! "${percent}" =~ ^[0-9]+$ ]]; then
    percent=0
  fi
  if (( percent < 0 )); then
    percent=0
  elif (( percent > 100 )); then
    percent=100
  fi

  filled=$((percent * width / 100))
  empty=$((width - filled))
  for ((i = 0; i < filled; i++)); do bar+="#"; done
  for ((i = 0; i < empty; i++)); do bar+="."; done
  printf '%s' "${bar}"
}

percent_style_code() {
  local percent="$1"
  if [[ -z "${percent}" || ! "${percent}" =~ ^[0-9]+$ ]]; then
    echo "0"
    return 0
  fi
  if (( percent >= 90 )); then
    echo "31"
  elif (( percent >= 70 )); then
    echo "33"
  else
    echo "32"
  fi
}

short_id() {
  local id="$1"
  if [[ -z "${id}" || "${id}" == "unknown" ]]; then
    echo "unknown"
    return 0
  fi
  local len="${#id}"
  if (( len <= 14 )); then
    echo "${id}"
    return 0
  fi
  echo "${id:0:8}..${id:len-6:6}"
}

validate_saved_account_exists() {
  local account="$1"
  local primary="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"

  if [[ ! -f "${primary}" && ! -f "${legacy_store}" && ! -f "${legacy_opencode}" ]]; then
    fail "Account not found in saved store: ${account}"
  fi
}

saved_account_id_by_name() {
  local account="$1"
  local primary="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local source=""

  if [[ -f "${primary}" ]]; then
    source="${primary}"
  elif [[ -f "${legacy_store}" ]]; then
    source="${legacy_store}"
  elif [[ -f "${legacy_opencode}" ]]; then
    source="${legacy_opencode}"
  else
    echo ""
    return 0
  fi

  account_id_from_saved_file "${source}"
}

pool_has_account() {
  local account="$1"
  jq -e --arg account "${account}" '.accounts | index($account) != null' "${CODEX_POOL_FILE}" >/dev/null 2>&1
}

saved_account_names_raw() {
  find "${STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null     | sed 's#^.*/##'     | sed 's#\.json$##'     | sort
}

saved_account_count() {
  saved_account_names_raw | wc -l | tr -d ' '
}

in_list() {
  local needle="$1"
  shift
  local item
  for item in "$@"; do
    if [[ "${item}" == "${needle}" ]]; then
      return 0
    fi
  done
  return 1
}

pool_reconcile_saved_accounts() {
  local saved=()
  local current=()
  local final=()
  local account
  local tmp
  local changed=0

  ensure_codex_pool_file

  while IFS= read -r account; do
    [[ -z "${account}" ]] || saved+=("${account}")
  done < <(saved_account_names_raw)
  [[ "${#saved[@]}" -gt 0 ]] || fail "No saved accounts available to reconcile into the pool."

  while IFS= read -r account; do
    [[ -z "${account}" ]] || current+=("${account}")
  done < <(pool_list_accounts)

  for account in "${current[@]}"; do
    if in_list "${account}" "${saved[@]}"; then
      final+=("${account}")
    else
      changed=1
    fi
  done

  for account in "${saved[@]}"; do
    if ! in_list "${account}" "${final[@]}"; then
      final+=("${account}")
      changed=1
    fi
  done

  [[ "${#final[@]}" -gt 0 ]] || fail "Unable to reconcile pool: no valid saved accounts."

  if [[ "${changed}" -eq 0 ]]; then
    return 1
  fi

  tmp="$(new_tmp)"
  jq \
    --arg updated_at "$(now_utc)" \
    '.last_account as $last
     | .accounts = $ARGS.positional
     | .cooldowns = ((.cooldowns // {}) | to_entries | map(select(.key as $k | ($ARGS.positional | index($k)) != null)) | from_entries)
     | .last_account = (if ($last != null and ($ARGS.positional | index($last)) == null) then null else $last end)
     | .updated_at = $updated_at' \
    "${CODEX_POOL_FILE}" \
    --args "${final[@]}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
  echo "Reconciled Codex rotation pool with saved accounts."
  return 0
}

pool_sync_saved_accounts() {
  local names=()
  local name

  while IFS= read -r name; do
    [[ -z "${name}" ]] || names+=("${name}")
  done < <(saved_account_names_raw)

  [[ "${#names[@]}" -gt 0 ]] || fail "No saved accounts available to sync into the pool."
  pool_set_accounts "${names[@]}"
}

pool_set_accounts() {
  local accounts=("$@")
  local account
  local tmp

  ensure_codex_pool_file
  [[ "${#accounts[@]}" -gt 0 ]] || fail "Usage: ai pool-set <account> [account...]"

  for account in "${accounts[@]}"; do
    validate_account_name "${account}"
    validate_saved_account_exists "${account}"
  done

  tmp="$(new_tmp)"
  jq -n \
    --arg updated_at "$(now_utc)" \
    '{accounts: $ARGS.positional, cooldowns: {}, last_account: null, updated_at: $updated_at}' \
    --args "${accounts[@]}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
  echo "Codex rotation pool set to: ${accounts[*]}"
}

pool_add_accounts() {
  local accounts=("$@")
  local account
  local tmp

  ensure_codex_pool_file
  [[ "${#accounts[@]}" -gt 0 ]] || fail "Usage: ai pool-add <account> [account...]"

  for account in "${accounts[@]}"; do
    validate_account_name "${account}"
    validate_saved_account_exists "${account}"
  done

  tmp="$(new_tmp)"
  jq \
    --arg updated_at "$(now_utc)" \
    '.accounts = ((.accounts + $ARGS.positional) | unique)
     | .updated_at = $updated_at' \
    "${CODEX_POOL_FILE}" \
    --args "${accounts[@]}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
  echo "Added to Codex rotation pool: ${accounts[*]}"
}

pool_remove_accounts() {
  local accounts=("$@")
  local account
  local tmp

  ensure_codex_pool_file
  [[ "${#accounts[@]}" -gt 0 ]] || fail "Usage: ai pool-remove <account> [account...]"

  for account in "${accounts[@]}"; do
    validate_account_name "${account}"
  done

  tmp="$(new_tmp)"
  jq \
    --arg updated_at "$(now_utc)" \
    '.accounts = [.accounts[] | select(($ARGS.positional | index(.)) == null)]
     | .cooldowns = ((.cooldowns // {}) | to_entries | map(select(.key as $k | ($ARGS.positional | index($k)) == null)) | from_entries)
     | .last_account = (if (.last_account != null and ($ARGS.positional | index(.last_account)) != null) then null else .last_account end)
     | .updated_at = $updated_at' \
    "${CODEX_POOL_FILE}" \
    --args "${accounts[@]}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
  echo "Removed from Codex rotation pool: ${accounts[*]}"
}

pool_reset_cooldowns() {
  local accounts=("$@")
  local tmp
  local account

  ensure_codex_pool_file
  tmp="$(new_tmp)"

  if [[ "${#accounts[@]}" -eq 0 ]]; then
    jq --arg updated_at "$(now_utc)" '
      .cooldowns = {}
      | .updated_at = $updated_at
    ' "${CODEX_POOL_FILE}" > "${tmp}"
    mv "${tmp}" "${CODEX_POOL_FILE}"
    chmod 600 "${CODEX_POOL_FILE}" || true
    echo "Cleared all Codex pool cooldowns."
    return 0
  fi

  for account in "${accounts[@]}"; do
    validate_account_name "${account}"
  done

  jq \
    --arg updated_at "$(now_utc)" \
    '.cooldowns = ((.cooldowns // {}) | to_entries | map(select(.key as $k | ($ARGS.positional | index($k)) == null)) | from_entries)
     | .updated_at = $updated_at' \
    "${CODEX_POOL_FILE}" \
    --args "${accounts[@]}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
  echo "Cleared Codex pool cooldowns for: ${accounts[*]}"
}

pool_list_accounts() {
  ensure_codex_pool_file
  jq -r '.accounts[]?' "${CODEX_POOL_FILE}"
}

pool_status() {
  local tmp
  local now_epoch
  local account
  local until_epoch
  local reason
  local remaining
  local status_label

  ensure_codex_pool_file
  tmp="$(new_tmp)"
  now_epoch="$(date +%s)"
  jq \
    --arg now "$(date +%s)" \
    '{
      accounts: (.accounts // []),
      last_account: (.last_account // null),
      cooldowns: (
        .cooldowns // {}
        | with_entries(.value = (
            if ((.value.until_epoch // 0) | tonumber) > ($now | tonumber) then
              .value + {active: true}
            else
              .value + {active: false}
            end
          ))
      )
    }' "${CODEX_POOL_FILE}" > "${tmp}"

  echo "Codex rotation pool:"
  jq -r '
    if (.accounts | length) == 0 then
      "  (empty)"
    else
      .accounts[] | "  " + .
    end
  ' "${tmp}"

  echo "Last selected: $(jq -r '.last_account // "none"' "${tmp}")"
  echo "Cooldowns:"
  if [[ "$(jq '.cooldowns | keys | length' "${tmp}")" -eq 0 ]]; then
    echo "  none"
    return 0
  fi

  while IFS=$'\t' read -r account until_epoch reason; do
    [[ -n "${account}" ]] || continue
    if [[ "${until_epoch}" =~ ^[0-9]+$ ]] && (( until_epoch > now_epoch )); then
      remaining=$((until_epoch - now_epoch))
      status_label="active"
    else
      remaining=0
      status_label="expired"
    fi
    echo "  ${account}: ${status_label}, reason=${reason:-unknown}, until $(format_epoch_utc "${until_epoch}") (in $(format_duration "${remaining}"))"
  done < <(
    jq -r '
      .cooldowns
      | to_entries[]
      | [
          .key,
          ((.value.until_epoch // 0) | tostring),
          (.value.reason // "unknown")
        ]
      | @tsv
    ' "${tmp}"
  )
}

pool_next_account() {
  local exclude_account="${1:-}"
  local now_epoch
  local account

  ensure_codex_pool_file
  now_epoch="$(date +%s)"

  while IFS= read -r account; do
    [[ -n "${account}" ]] || continue
    if [[ -n "${exclude_account}" && "${account}" == "${exclude_account}" ]]; then
      continue
    fi
    if jq -e --arg account "${account}" --arg now "${now_epoch}" '
      (.cooldowns[$account].until_epoch // 0) <= ($now | tonumber)
    ' "${CODEX_POOL_FILE}" >/dev/null 2>&1; then
      echo "${account}"
      return 0
    fi
  done < <(
    jq -r '
      .accounts as $accounts
      | .last_account as $last
      | if ($accounts | length) == 0 then
          empty
        elif $last == null then
          $accounts[]
        else
          (($accounts | index($last)) // -1) as $idx
          | [range(1; ($accounts | length) + 1) | $accounts[(($idx + .) % ($accounts | length))]] | .[]
        end
    ' "${CODEX_POOL_FILE}"
  )

  return 1
}

pool_mark_selected() {
  local account="$1"
  local tmp

  ensure_codex_pool_file
  tmp="$(new_tmp)"
  jq --arg account "${account}" --arg updated_at "$(now_utc)" '
    .last_account = $account
    | .updated_at = $updated_at
  ' "${CODEX_POOL_FILE}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
}

pool_mark_cooldown() {
  local account="$1"
  local until_epoch="$2"
  local reason="$3"
  local tmp

  ensure_codex_pool_file
  tmp="$(new_tmp)"
  jq \
    --arg account "${account}" \
    --arg reason "${reason}" \
    --arg updated_at "$(now_utc)" \
    --argjson until_epoch "${until_epoch}" '
    .cooldowns = (.cooldowns // {})
    | .cooldowns[$account] = {
        until_epoch: $until_epoch,
        reason: $reason,
        updated_at: $updated_at
      }
    | .updated_at = $updated_at
  ' "${CODEX_POOL_FILE}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true
}

pool_account_available() {
  local account="$1"
  local now_epoch
  ensure_codex_pool_file
  [[ -n "${account}" ]] || return 1
  now_epoch="$(date +%s)"
  jq -e --arg account "${account}" --arg now "${now_epoch}" '
    (.accounts | index($account)) != null
    and ((.cooldowns[$account].until_epoch // 0) <= ($now | tonumber))
  ' "${CODEX_POOL_FILE}" >/dev/null 2>&1
}

update_managed_codex_session_state() {
  local session_id="$1"
  local session_file="$2"
  local cwd="$3"
  local account="$4"
  local pending_resume="$5"
  local last_exit_reason="$6"
  local tmp

  ensure_codex_session_state_file
  tmp="$(new_tmp)"
  jq \
    --arg session_id "${session_id}" \
    --arg session_file "${session_file}" \
    --arg cwd "${cwd}" \
    --arg account "${account}" \
    --arg last_exit_reason "${last_exit_reason}" \
    --arg updated_at "$(now_utc)" \
    --argjson pending_resume "${pending_resume}" '
    .session_id = (if $session_id == "" then null else $session_id end)
    | .session_file = (if $session_file == "" then null else $session_file end)
    | .cwd = (if $cwd == "" then null else $cwd end)
    | .account = (if $account == "" then null else $account end)
    | .pending_resume = $pending_resume
    | .last_exit_reason = (if $last_exit_reason == "" then null else $last_exit_reason end)
    | .updated_at = $updated_at
  ' "${CODEX_SESSION_STATE_FILE}" > "${tmp}"
  mv "${tmp}" "${CODEX_SESSION_STATE_FILE}"
  chmod 600 "${CODEX_SESSION_STATE_FILE}" || true
}

resolve_pending_managed_codex_resume() {
  local cwd_filter="$1"
  local stored_session_id=""
  local stored_account=""
  local stored_cwd=""
  local normalized_stored=""
  local normalized_filter=""

  ensure_codex_session_state_file
  stored_session_id="$(jq -r '.session_id // empty' "${CODEX_SESSION_STATE_FILE}")"
  stored_account="$(jq -r '.account // empty' "${CODEX_SESSION_STATE_FILE}")"
  stored_cwd="$(jq -r '.cwd // empty' "${CODEX_SESSION_STATE_FILE}")"

  [[ "$(jq -r '.pending_resume // false' "${CODEX_SESSION_STATE_FILE}")" == "true" ]] || return 1
  [[ -n "${stored_session_id}" ]] || return 1

  if [[ -n "${cwd_filter}" && -n "${stored_cwd}" ]]; then
    if [[ "${stored_cwd}" != "${cwd_filter}" ]]; then
      normalized_stored="$(normalize_path "${stored_cwd}" || true)"
      normalized_filter="$(normalize_path "${cwd_filter}" || true)"
      [[ -n "${normalized_stored}" && -n "${normalized_filter}" && "${normalized_stored}" == "${normalized_filter}" ]] || return 1
    fi
  fi

  printf '%s\t%s\n' "${stored_session_id}" "${stored_account}"
}

pool_set_manual_cooldown() {
  local account="$1"
  local duration_seconds="${2:-${DEFAULT_RATE_LIMIT_COOLDOWN_SECONDS}}"
  local until_epoch

  ensure_codex_pool_file
  validate_account_name "${account}"
  pool_has_account "${account}" || fail "Account is not in the Codex rotation pool: ${account}"
  [[ "${duration_seconds}" =~ ^[0-9]+$ ]] || fail "Cooldown seconds must be an integer."
  until_epoch=$(( $(date +%s) + duration_seconds ))
  pool_mark_cooldown "${account}" "${until_epoch}" "manual"
  echo "Marked '${account}' on cooldown for ${duration_seconds}s."
}

codex_wrapper_body() {
  local ai_path="$1"
  local real_bin="$2"
  cat <<EOF
#!/usr/bin/env bash
set -euo pipefail
export AI_SWITCH_CODEX_BIN="${real_bin}"
export AI_SWITCH_WRAPPER_SELF="\$0"
exec "${ai_path}" codex "\$@"
EOF
}

codex_wrapper_installed() {
  local target="${1:-${DEFAULT_CODEX_WRAPPER_TARGET}}"
  [[ -f "${target}" ]] || return 1
  grep -q 'AI_SWITCH_WRAPPER_SELF' "${target}" 2>/dev/null
}

codex_wrapper_status() {
  local target="${1:-${DEFAULT_CODEX_WRAPPER_TARGET}}"
  local backup="${2:-${DEFAULT_CODEX_WRAPPER_BACKUP}}"

  echo "Codex wrapper target: ${target}"
  if codex_wrapper_installed "${target}"; then
    echo "Status: installed"
  else
    echo "Status: not installed"
  fi

  if [[ -f "${backup}" ]]; then
    echo "Backup: ${backup}"
  else
    echo "Backup: missing"
  fi
}

install_codex_wrapper() {
  local target="${1:-${DEFAULT_CODEX_WRAPPER_TARGET}}"
  local backup="${2:-${DEFAULT_CODEX_WRAPPER_BACKUP}}"
  local ai_path
  local target_dir
  local tmp

  ai_path="$(readlink -f "$0" 2>/dev/null || echo "$0")"
  target_dir="$(dirname "${target}")"
  mkdir -p "${target_dir}"

  if codex_wrapper_installed "${target}"; then
    echo "Codex wrapper already installed at ${target}"
    return 0
  fi

  if [[ ! -f "${target}" ]]; then
    fail "No existing codex entrypoint found at ${target}. Create one first or pass a different target path."
  fi

  if [[ ! -f "${backup}" ]]; then
    cp "${target}" "${backup}"
    chmod +x "${backup}" || true
  fi

  tmp="$(new_tmp)"
  codex_wrapper_body "${ai_path}" "${backup}" > "${tmp}"
  mv "${tmp}" "${target}"
  chmod +x "${target}" || true
  echo "Installed ai-switch Codex wrapper at ${target}"
  echo "Backup real Codex entrypoint: ${backup}"
}

uninstall_codex_wrapper() {
  local target="${1:-${DEFAULT_CODEX_WRAPPER_TARGET}}"
  local backup="${2:-${DEFAULT_CODEX_WRAPPER_BACKUP}}"

  codex_wrapper_installed "${target}" || fail "No ai-switch wrapper is installed at ${target}."
  [[ -f "${backup}" ]] || fail "Cannot restore wrapper target because backup is missing: ${backup}"

  cp "${backup}" "${target}"
  chmod +x "${target}" || true
  echo "Restored Codex entrypoint from ${backup}"
}

validate_codex_auth_file() {
  local file="$1"
  [[ -f "${file}" ]] || fail "Codex auth file not found at ${file}."
  jq -e 'type == "object" and has("auth_mode") and has("tokens")' "${file}" >/dev/null \
    || fail "Invalid Codex auth JSON in ${file}."
  jq -e '.tokens | has("access_token") and has("refresh_token") and has("account_id")' "${file}" >/dev/null \
    || fail "Codex auth tokens missing required fields in ${file}."
}

validate_opencode_auth_file() {
  local file="$1"
  [[ -f "${file}" ]] || fail "OpenCode auth file not found at ${file}."
  jq -e 'type == "object" and has("openai") and (.openai | type == "object")' "${file}" >/dev/null \
    || fail "Invalid OpenCode auth JSON in ${file}."
  jq -e '.openai | has("access") and has("refresh") and has("accountId")' "${file}" >/dev/null \
    || fail "OpenCode auth .openai section is missing required fields in ${file}."
}

validate_openai_object_file() {
  local file="$1"
  [[ -f "${file}" ]] || fail "Account file not found: ${file}."
  jq -e 'type == "object" and has("access") and has("refresh") and has("accountId")' "${file}" >/dev/null \
    || fail "Invalid OpenCode account JSON in ${file}."
}

build_unified_from_codex_file() {
  local file="$1"
  local tokens_json
  local auth_mode
  local openai_api_key
  local last_refresh
  local updated_at

  validate_codex_auth_file "${file}"

  tokens_json="$(jq -c '.tokens' "${file}")"
  auth_mode="$(jq -r '.auth_mode // "chatgpt"' "${file}")"
  openai_api_key="$(jq -c '.OPENAI_API_KEY' "${file}")"
  last_refresh="$(jq -r '.last_refresh // ""' "${file}")"
  updated_at="$(now_utc)"

  jq -n \
    --arg format "${UNIFIED_FORMAT}" \
    --arg updated_at "${updated_at}" \
    --arg auth_mode "${auth_mode}" \
    --arg last_refresh "${last_refresh}" \
    --argjson openai_api_key "${openai_api_key}" \
    --argjson tokens "${tokens_json}" \
    '{
      format: $format,
      version: 1,
      updated_at: $updated_at,
      source: "codex",
      tokens: ($tokens + {id_token: ($tokens.id_token // null)}),
      opencode: { expires: null, type: null },
      codex: {
        auth_mode: $auth_mode,
        openai_api_key: $openai_api_key,
        last_refresh: (if $last_refresh == "" then null else $last_refresh end)
      }
    }'
}

build_unified_from_openai_json() {
  local openai_json="$1"
  local updated_at

  updated_at="$(now_utc)"

  jq -n \
    --arg format "${UNIFIED_FORMAT}" \
    --arg updated_at "${updated_at}" \
    --argjson openai "${openai_json}" \
    '{
      format: $format,
      version: 1,
      updated_at: $updated_at,
      source: "opencode",
      tokens: {
        access_token: $openai.access,
        refresh_token: $openai.refresh,
        account_id: $openai.accountId,
        id_token: null
      },
      opencode: {
        expires: ($openai.expires // null),
        type: ($openai.type // null)
      },
      codex: {
        auth_mode: "chatgpt",
        openai_api_key: null,
        last_refresh: null
      }
    }'
}

build_unified_from_openai_object_file() {
  local file="$1"
  local openai_json

  validate_openai_object_file "${file}"
  openai_json="$(jq -c '.' "${file}")"
  build_unified_from_openai_json "${openai_json}"
}

build_unified_from_opencode_auth_file() {
  local file="$1"
  local openai_json

  validate_opencode_auth_file "${file}"
  openai_json="$(jq -c '.openai' "${file}")"
  build_unified_from_openai_json "${openai_json}"
}

try_build_unified_from_codex_file() {
  local file="$1"
  local tokens_json
  local auth_mode
  local openai_api_key
  local last_refresh
  local updated_at

  if ! jq -e 'type == "object" and has("auth_mode") and has("tokens") and (.tokens | has("access_token") and has("refresh_token") and has("account_id"))' "${file}" >/dev/null 2>&1; then
    return 1
  fi

  tokens_json="$(jq -c '.tokens' "${file}" 2>/dev/null)" || return 1
  auth_mode="$(jq -r '.auth_mode // "chatgpt"' "${file}" 2>/dev/null)" || return 1
  openai_api_key="$(jq -c '.OPENAI_API_KEY' "${file}" 2>/dev/null)" || return 1
  last_refresh="$(jq -r '.last_refresh // ""' "${file}" 2>/dev/null)" || return 1
  updated_at="$(now_utc)"

  jq -n \
    --arg format "${UNIFIED_FORMAT}" \
    --arg updated_at "${updated_at}" \
    --arg auth_mode "${auth_mode}" \
    --arg last_refresh "${last_refresh}" \
    --argjson openai_api_key "${openai_api_key}" \
    --argjson tokens "${tokens_json}" \
    '{
      format: $format,
      version: 1,
      updated_at: $updated_at,
      source: "codex",
      tokens: ($tokens + {id_token: ($tokens.id_token // null)}),
      opencode: { expires: null, type: null },
      codex: {
        auth_mode: $auth_mode,
        openai_api_key: $openai_api_key,
        last_refresh: (if $last_refresh == "" then null else $last_refresh end)
      }
    }'
}

try_build_unified_from_openai_object_file() {
  local file="$1"
  local openai_json

  if ! jq -e 'type == "object" and has("access") and has("refresh") and has("accountId")' "${file}" >/dev/null 2>&1; then
    return 1
  fi

  openai_json="$(jq -c '.' "${file}" 2>/dev/null)" || return 1
  build_unified_from_openai_json "${openai_json}"
}

normalize_saved_file() {
  local file="$1"

  if jq -e ".format == \"${UNIFIED_FORMAT}\"" "${file}" >/dev/null 2>&1; then
    cat "${file}"
    return 0
  fi

  if jq -e 'has("auth_mode") and has("tokens")' "${file}" >/dev/null 2>&1; then
    build_unified_from_codex_file "${file}"
    return 0
  fi

  if jq -e 'has("access") and has("accountId")' "${file}" >/dev/null 2>&1; then
    build_unified_from_openai_object_file "${file}"
    return 0
  fi

  return 1
}

normalize_saved_file_or_fail() {
  local file="$1"
  normalize_saved_file "${file}" || fail "Unsupported account format in ${file}."
}

merge_unified_files() {
  local existing="$1"
  local incoming="$2"

  jq -n --slurpfile existing "${existing}" --slurpfile incoming "${incoming}" '
    def pick(new; old):
      if new == null or new == "" then old else new end;
    $incoming[0] as $n | $existing[0] as $e |
    $n
    | .source = "mixed"
    | .tokens.id_token = pick(.tokens.id_token; $e.tokens.id_token)
    | .opencode.expires = pick(.opencode.expires; $e.opencode.expires)
    | .opencode.type = pick(.opencode.type; $e.opencode.type)
    | .codex.auth_mode = pick(.codex.auth_mode; $e.codex.auth_mode)
    | .codex.openai_api_key = (if .codex.openai_api_key == null then $e.codex.openai_api_key else .codex.openai_api_key end)
    | .codex.last_refresh = pick(.codex.last_refresh; $e.codex.last_refresh)
  '
}

check_unified_file() {
  local file="$1"
  jq -e --arg format "${UNIFIED_FORMAT}" '
    type == "object"
    and .format == $format
    and (.version == 1)
    and (.tokens | type == "object")
    and (.tokens.access_token | type == "string")
    and (.tokens.refresh_token | type == "string")
    and (.tokens.account_id | type == "string")
  ' "${file}" >/dev/null 2>&1
}

validate_unified_file() {
  local file="$1"
  check_unified_file "${file}" || fail "Invalid unified account file: ${file}."
}

account_id_from_saved_file() {
  local file="$1"
  local account_id=""

  if jq -e ".format == \"${UNIFIED_FORMAT}\"" "${file}" >/dev/null 2>&1; then
    account_id="$(jq -r '.tokens.account_id // empty' "${file}" 2>/dev/null || true)"
  elif jq -e 'has("auth_mode") and has("tokens")' "${file}" >/dev/null 2>&1; then
    account_id="$(jq -r '.tokens.account_id // empty' "${file}" 2>/dev/null || true)"
  elif jq -e 'has("access") and has("accountId")' "${file}" >/dev/null 2>&1; then
    account_id="$(jq -r '.accountId // empty' "${file}" 2>/dev/null || true)"
  fi

  echo "${account_id}"
}

list_accounts() {
  local files
  local file
  local name
  local any=0
  declare -A seen=()

  files=$(find "${STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    if [[ -z "${seen[${name}]+x}" ]]; then
      echo "${name}"
      seen["${name}"]=1
      any=1
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    if [[ -z "${seen[${name}]+x}" ]]; then
      echo "${name}"
      seen["${name}"]=1
      any=1
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_OPENCODE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    if [[ -z "${seen[${name}]+x}" ]]; then
      echo "${name}"
      seen["${name}"]=1
      any=1
    fi
  done <<< "${files}"

  if [[ "${any}" -eq 0 ]]; then
    echo "No saved accounts found in ${STORE_DIR} or legacy stores."
    return 0
  fi
}

find_account_name_by_account_id() {
  local account_id="$1"
  local file
  local saved_account_id
  local files

  files=$(find "${STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    saved_account_id="$(account_id_from_saved_file "${file}")"
    if [[ -n "${saved_account_id}" && "${saved_account_id}" == "${account_id}" ]]; then
      basename "${file}" .json
      return 0
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    saved_account_id="$(account_id_from_saved_file "${file}")"
    if [[ -n "${saved_account_id}" && "${saved_account_id}" == "${account_id}" ]]; then
      basename "${file}" .json
      return 0
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_OPENCODE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    saved_account_id="$(account_id_from_saved_file "${file}")"
    if [[ -n "${saved_account_id}" && "${saved_account_id}" == "${account_id}" ]]; then
      basename "${file}" .json
      return 0
    fi
  done <<< "${files}"

  return 1
}

active_account_for_platform() {
  local platform="$1"
  local account_id=""
  local match=""

  case "${platform}" in
    codex)
      if [[ ! -f "${CODEX_AUTH_FILE}" ]]; then
        echo "not configured"
        return 0
      fi
      account_id="$(jq -r '.tokens.account_id // empty' "${CODEX_AUTH_FILE}" 2>/dev/null || true)"
      ;;
    opencode)
      if [[ ! -f "${OPENCODE_AUTH_FILE}" ]]; then
        echo "not configured"
        return 0
      fi
      account_id="$(jq -r '.openai.accountId // empty' "${OPENCODE_AUTH_FILE}" 2>/dev/null || true)"
      ;;
    *)
      echo "unknown"
      return 0
      ;;
  esac

  if [[ -z "${account_id}" ]]; then
    echo "unknown"
    return 0
  fi

  if match="$(find_account_name_by_account_id "${account_id}" 2>/dev/null)"; then
    echo "${match}"
    return 0
  fi

  echo "unknown"
}

list_active_profiles() {
  local codex_active
  local opencode_active

  codex_active="$(active_account_for_platform codex)"
  opencode_active="$(active_account_for_platform opencode)"

  echo "Active accounts:"
  echo "  Codex: ${codex_active}"
  echo "  OpenCode: ${opencode_active}"
}

show_usage_limits() {
  local active_account=""
  local snapshot=""
  local p_used=""
  local p_reset=""
  local s_used=""
  local s_reset=""
  local now_epoch
  local p_pct
  local s_pct
  local p_in="unknown"
  local s_in="unknown"

  ensure_codex_limits_file
  refresh_active_account_limits_from_latest_session >/dev/null 2>&1 || true

  active_account="$(active_account_for_platform codex)"
  case "${active_account}" in
    ""|unknown|not\ configured)
      warn "Could not determine active Codex account."
      return 1
      ;;
  esac

  snapshot="$(jq -rc --arg account "${active_account}" '.accounts[$account] // empty' "${CODEX_LIMITS_FILE}" || true)"
  if [[ -z "${snapshot}" ]]; then
    warn "No limits snapshot available for '${active_account}'. Run: ai status --refresh"
    return 1
  fi

  p_used="$(jq -r '.primary.used_percent // empty' <<< "${snapshot}")"
  p_reset="$(jq -r '.primary.resets_at // empty' <<< "${snapshot}")"
  s_used="$(jq -r '.secondary.used_percent // empty' <<< "${snapshot}")"
  s_reset="$(jq -r '.secondary.resets_at // empty' <<< "${snapshot}")"
  now_epoch="$(date +%s)"
  if [[ "${p_reset}" =~ ^[0-9]+$ ]]; then
    p_in="$(format_duration "$((p_reset - now_epoch))")"
  fi
  if [[ "${s_reset}" =~ ^[0-9]+$ ]]; then
    s_in="$(format_duration "$((s_reset - now_epoch))")"
  fi

  p_pct="$(format_percent "${p_used}")"
  s_pct="$(format_percent "${s_used}")"
  echo "5h ${p_pct}% (resets $(format_epoch_utc "${p_reset}"), in ${p_in}) · weekly ${s_pct}% (resets $(format_epoch_utc "${s_reset}"), in ${s_in})"
}

