is_managed_codex_supported_args() {
  local args=("$@")
  local arg
  local consumed_value=0

  for arg in "${args[@]}"; do
    if [[ "${consumed_value}" -eq 1 ]]; then
      consumed_value=0
      continue
    fi

    case "${arg}" in
      exec|review|login|logout|mcp|mcp-server|app-server|completion|sandbox|debug|apply|fork|cloud|features|help)
        return 1
        ;;
      -c|--config|--enable|--disable|--remote|--remote-auth-token-env|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        consumed_value=1
        ;;
      --config=*|--enable=*|--disable=*|--remote=*|--remote-auth-token-env=*|--image=*|--model=*|--local-provider=*|--profile=*|--sandbox=*|--ask-for-approval=*|--cd=*|--add-dir=*)
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|--last|--all|--include-non-interactive)
        ;;
      --)
        return 0
        ;;
      -*)
        ;;
      *)
        if [[ "${arg}" == "resume" ]]; then
          return 0
        fi
        return 0
        ;;
    esac
  done

  return 0
}

extract_resume_global_args() {
  local args=("$@")
  local arg
  local out=()
  local consumed_value=0

  for arg in "${args[@]}"; do
    if [[ "${consumed_value}" -eq 1 ]]; then
      out+=("${arg}")
      consumed_value=0
      continue
    fi

    case "${arg}" in
      -c|--config|--enable|--disable|--remote|--remote-auth-token-env|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        out+=("${arg}")
        consumed_value=1
        ;;
      --config=*|--enable=*|--disable=*|--remote=*|--remote-auth-token-env=*|--image=*|--model=*|--local-provider=*|--profile=*|--sandbox=*|--ask-for-approval=*|--cd=*|--add-dir=*)
        out+=("${arg}")
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen|--yolo)
        out+=("${arg}")
        ;;
      resume)
        break
        ;;
      -*)
        ;;
      *)
        break
        ;;
    esac
  done

  printf '%s\n' "${out[@]}"
}

extract_resume_target() {
  local args=("$@")
  local idx=0
  local arg

  while [[ "${idx}" -lt "${#args[@]}" ]]; do
    arg="${args[${idx}]}"
    case "${arg}" in
      -c|--config|--enable|--disable|--remote|--remote-auth-token-env|-i|--image|-m|--model|--local-provider|-p|--profile|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--add-dir)
        idx=$((idx + 2))
        continue
        ;;
      --config=*|--enable=*|--disable=*|--remote=*|--remote-auth-token-env=*|--image=*|--model=*|--local-provider=*|--profile=*|--sandbox=*|--ask-for-approval=*|--cd=*|--add-dir=*|--oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--search|--no-alt-screen)
        idx=$((idx + 1))
        continue
        ;;
      resume)
        idx=$((idx + 1))
        while [[ "${idx}" -lt "${#args[@]}" ]]; do
          arg="${args[${idx}]}"
          case "${arg}" in
            --last)
              echo "__LAST__"
              return 0
              ;;
            --all|--include-non-interactive)
              idx=$((idx + 1))
              ;;
            -*)
              idx=$((idx + 1))
              ;;
            *)
              echo "${arg}"
              return 0
              ;;
          esac
        done
        return 0
        ;;
      *)
        return 0
        ;;
    esac
  done
}

extract_session_id_from_file() {
  local file="$1"
  local id=""
  [[ -f "${file}" ]] || return 1
  id="$(jq -r 'select(.type == "session_meta") | .payload.id // empty' "${file}" | head -n 1)"
  [[ -n "${id}" ]] || return 1
  echo "${id}"
}

detect_recent_session_file() {
  local newer_than="$1"
  local cwd_filter="$2"
  local preferred_session_id="${3:-}"
  local candidate=""
  local first_matching_cwd=""
  local first_matching_session=""

  while IFS= read -r candidate; do
    [[ -n "${candidate}" ]] || continue

    if [[ -n "${newer_than}" && ! "${candidate}" -nt "${newer_than}" ]]; then
      continue
    fi

    if [[ -n "${preferred_session_id}" ]] && jq -e --arg id "${preferred_session_id}" '
      select(.type == "session_meta" and .payload.id == $id)
    ' "${candidate}" >/dev/null 2>&1; then
      echo "${candidate}"
      return 0
    fi

    if session_file_matches_cwd "${candidate}" "${cwd_filter}"; then
      echo "${candidate}"
      return 0
    fi
  done < <(list_session_files_newest)

  if [[ -n "${preferred_session_id}" ]]; then
    first_matching_session="$(find_session_file_by_id "${preferred_session_id}" || true)"
    if [[ -n "${first_matching_session}" ]]; then
      echo "${first_matching_session}"
      return 0
    fi
  fi

  while IFS= read -r candidate; do
    [[ -n "${candidate}" ]] || continue
    if session_file_matches_cwd "${candidate}" "${cwd_filter}"; then
      first_matching_cwd="${candidate}"
      break
    fi
  done < <(list_session_files_newest)

  if [[ -n "${first_matching_cwd}" ]]; then
    echo "${first_matching_cwd}"
    return 0
  fi

  return 1
}

detect_recent_session_id() {
  local newer_than="$1"
  local cwd_filter="$2"
  local file=""
  file="$(detect_recent_session_file "${newer_than}" "${cwd_filter}" || true)"
  [[ -n "${file}" ]] || return 1
  extract_session_id_from_file "${file}"
}

resolve_last_session_file() {
  local file=""
  file="$(list_session_files_newest | head -n 1)"
  [[ -n "${file}" ]] || return 1
  echo "${file}"
}

resolve_last_session_id() {
  local file=""
  file="$(resolve_last_session_file || true)"
  [[ -n "${file}" ]] || return 1
  extract_session_id_from_file "${file}"
}

find_session_file_by_id() {
  local session_id="$1"
  local candidate=""
  [[ -n "${session_id}" ]] || return 1
  while IFS= read -r candidate; do
    [[ -n "${candidate}" ]] || continue
    if jq -e --arg id "${session_id}" '
      select(.type == "session_meta" and .payload.id == $id)
    ' "${candidate}" >/dev/null 2>&1; then
      echo "${candidate}"
      return 0
    fi
  done < <(list_session_files_newest)
  return 1
}

extract_rate_limits_event_from_session_file() {
  local session_file="$1"
  [[ -f "${session_file}" ]] || return 1
  jq -rc '
    select(.type == "event_msg" and .payload.type == "token_count" and .payload.rate_limits != null)
    | {
        captured_at: (.timestamp // null),
        rate_limits: .payload.rate_limits
      }
  ' "${session_file}" | tail -n 1
}

cache_account_rate_limits() {
  local account="$1"
  local source="$2"
  local session_id="$3"
  local event_json="$4"
  local tmp

  [[ -n "${account}" && -n "${event_json}" ]] || return 1
  ensure_codex_limits_file
  tmp="$(new_tmp)"
  jq \
    --arg account "${account}" \
    --arg updated_at "$(now_utc)" \
    --arg source "${source}" \
    --arg session_id "${session_id}" \
    --argjson event "${event_json}" '
    .accounts = (.accounts // {})
    | .accounts[$account] = {
        captured_at: ($event.captured_at // $updated_at),
        source: $source,
        session_id: (if $session_id == "" then null else $session_id end),
        limit_id: ($event.rate_limits.limit_id // null),
        plan_type: ($event.rate_limits.plan_type // null),
        primary: ($event.rate_limits.primary // null),
        secondary: ($event.rate_limits.secondary // null),
        credits: ($event.rate_limits.credits // null)
      }
    | .updated_at = $updated_at
  ' "${CODEX_LIMITS_FILE}" > "${tmp}"
  mv "${tmp}" "${CODEX_LIMITS_FILE}"
  chmod 600 "${CODEX_LIMITS_FILE}" || true
}

cache_rate_limits_from_session_file() {
  local account="$1"
  local session_file="$2"
  local source="$3"
  local session_id="$4"
  local event_json=""

  [[ -n "${account}" && -f "${session_file}" ]] || return 1
  event_json="$(extract_rate_limits_event_from_session_file "${session_file}" || true)"
  [[ -n "${event_json}" ]] || return 1
  cache_account_rate_limits "${account}" "${source}" "${session_id}" "${event_json}"
}

refresh_active_account_limits_from_latest_session() {
  local active_account=""
  local latest_file=""
  local session_id=""

  active_account="$(active_account_for_platform codex)"
  case "${active_account}" in
    ""|unknown|not\ configured) return 1 ;;
  esac

  latest_file="$(resolve_last_session_file || true)"
  [[ -n "${latest_file}" ]] || return 1
  session_id="$(extract_session_id_from_file "${latest_file}" || true)"
  cache_rate_limits_from_session_file "${active_account}" "${latest_file}" "chatgpt-session" "${session_id}"
}

