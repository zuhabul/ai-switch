#!/usr/bin/env bash
set -euo pipefail

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
AI_SWITCH_HOME="${AI_SWITCH_HOME:-$HOME/.local/share/ai-switch}"

CODEX_AUTH_FILE="${CODEX_AUTH_FILE:-${CODEX_HOME}/auth.json}"
OPENCODE_AUTH_FILE="${OPENCODE_AUTH_FILE:-$HOME/.local/share/opencode/auth.json}"

STORE_DIR="${AI_SWITCH_HOME}/credentials"
STATE_DIR="${AI_SWITCH_HOME}/state"
RUNTIME_DIR="${AI_SWITCH_HOME}/runtime"
LEGACY_STORE_DIR="${CODEX_HOME}/credentials"
LEGACY_OPENCODE_DIR="${CODEX_HOME}/credentials/opencode-openai"
CODEX_POOL_FILE="${STATE_DIR}/codex-pool.json"
CODEX_LIMITS_FILE="${STATE_DIR}/codex-limits.json"
CODEX_SESSION_STATE_FILE="${STATE_DIR}/codex-session.json"
CODEX_LOG_DIR="${RUNTIME_DIR}/codex"
AI_SWITCH_CODEX_BIN="${AI_SWITCH_CODEX_BIN:-codex}"
AI_SWITCH_SCRIPT_BIN="${AI_SWITCH_SCRIPT_BIN:-script}"
DEFAULT_CODEX_WRAPPER_TARGET="${HOME}/.local/bin/codex"
DEFAULT_CODEX_WRAPPER_BACKUP="${HOME}/.local/bin/codex.ai-switch-real"
DEFAULT_RATE_LIMIT_COOLDOWN_SECONDS=$((6 * 60 * 60))
DEFAULT_HTTP_429_COOLDOWN_SECONDS=$((15 * 60))
STATUS_STALE_SECONDS=$((15 * 60))
STATUS_PROBE_START_WAIT_SECONDS=4
STATUS_PROBE_COMMAND_WAIT_SECONDS=2
STATUS_PROBE_EXIT_WAIT_SECONDS=8

# --- SYSTEM STATE MONITORING ---
# Capture original shell environment to detect drift in the dashboard
AI_SHELL_VAL="${AI_ACCOUNT:-none}"
# Note: We NO LONGER source sync.sh here. The script must rely on auth.json as the source of truth.
# --- SYSTEM STATE MONITORING END ---

UNIFIED_FORMAT="unified-openai-auth"

TMP_FILES=()
TMP_DIRS=()
cleanup() {
  local file
  for file in "${TMP_FILES[@]}"; do
    [[ -n "${file}" && -f "${file}" ]] && rm -f "${file}"
  done
  local dir
  for dir in "${TMP_DIRS[@]}"; do
    [[ -n "${dir}" && -d "${dir}" ]] && rm -rf "${dir}"
  done
}
trap cleanup EXIT

new_tmp() {
  local file
  file="$(mktemp)"
  TMP_FILES+=("${file}")
  echo "${file}"
}

new_tmp_dir() {
  local dir
  dir="$(mktemp -d)"
  TMP_DIRS+=("${dir}")
  echo "${dir}"
}

