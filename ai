rotate_best_account() {
  local do_refresh=1
  local unsafe_refresh=0
  local arg
  local accounts=()
  local account
  local now_epoch
  local active_account
  local best_account=""
  local did_any=0
  local reconcile_out=""

  while (( $# )); do
    arg="$1"
    shift
    case "${arg}" in
      --refresh)
        do_refresh=1
        ;;
      --no-refresh)
        do_refresh=0
        ;;
      --unsafe)
        unsafe_refresh=1
        ;;
      *)
        fail "Unknown argument for 'rotate': ${arg}"
        ;;
    esac
  done

  ensure_codex_pool_file
  ensure_codex_limits_file
  refresh_active_account_limits_from_latest_session >/dev/null 2>&1 || true
  reconcile_out="$(pool_reconcile_saved_accounts 2>/dev/null || true)"
  if [[ -n "${reconcile_out}" ]]; then
    echo "${reconcile_out}"
  fi

  while IFS= read -r account; do
    [[ -z "${account}" ]] || accounts+=("${account}")
  done < <(pool_list_accounts)
  [[ "${#accounts[@]}" -gt 0 ]] || fail "Codex pool is empty. Configure with: ai pool-set <account> [account...]"

  if [[ "${do_refresh}" -eq 1 ]]; then
    refresh_codex_limits_cache_for_accounts 1 "${unsafe_refresh}" "${accounts[@]}" || true
  fi

  now_epoch="$(date +%s)"
  active_account="$(active_account_for_platform codex)"
  best_account="$(select_best_ready_account "${now_epoch}" "${accounts[@]}" || true)"
  [[ -n "${best_account}" ]] || fail "No ready account available. All pool accounts are cooling down."

  if [[ "${best_account}" == "${active_account}" ]]; then
    pool_mark_selected "${best_account}"
    echo "Codex already on the most available ready account: ${best_account}"
    if platform_available opencode; then
      use_account_platform opencode "${best_account}" >/dev/null 2>&1 || true
    fi
    while IFS= read -r line; do
      echo "  ${line}"
    done < <(render_account_limit_brief "${best_account}" "${now_epoch}")
    return 0
  fi

  if platform_available codex; then
    use_account_platform codex "${best_account}" >/dev/null
    did_any=1
  fi
  if platform_available opencode; then
    use_account_platform opencode "${best_account}" >/dev/null 2>&1 || true
    did_any=1
  fi
  if [[ "${did_any}" -eq 0 ]]; then
    fail "No supported platform auth file found to apply rotated account."
  fi
  pool_mark_selected "${best_account}"
  echo "Rotated Codex account: ${active_account} -> ${best_account}"
  while IFS= read -r line; do
    echo "  ${line}"
  done < <(render_account_limit_brief "${best_account}" "${now_epoch}")

  if codex_process_running; then
    warn "Running Codex processes keep their current in-memory session. New turns/sessions pick up '${best_account}'."
  fi
}

