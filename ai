  local now_epoch="$3"
  local snapshot=""
  local captured_at=""
  local source=""
  local plan_type=""
  local primary_used=""
  local primary_reset=""
  local secondary_used=""
  local secondary_reset=""
  local cooldown_until=0
  local cooldown_active=0
  local captured_epoch=""
  local age_seconds=""
  local freshness_plain=""
  local freshness_view=""
  local state_badge_plain=""
  local state_badge_view=""
  local active_badge="-"
  local ready_badge="R"
  local p_cell=""
  local s_cell=""
  local plan_short=""
  local source_short=""
  local line_state=""
  local cooldown_cell="-"
  local source_cell="na"
  local left_cell=""

  snapshot="$(jq -rc --arg account "${account}" '.accounts[$account] // empty' "${CODEX_LIMITS_FILE}" || true)"
  captured_at="$(jq -r --arg account "${account}" '.accounts[$account].captured_at // empty' "${CODEX_LIMITS_FILE}")"
