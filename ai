#!/usr/bin/env bash
set -euo pipefail

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
AI_SWITCH_HOME="${AI_SWITCH_HOME:-$HOME/.local/share/ai-switch}"

CODEX_AUTH_FILE="${CODEX_AUTH_FILE:-${CODEX_HOME}/auth.json}"
OPENCODE_AUTH_FILE="${OPENCODE_AUTH_FILE:-$HOME/.local/share/opencode/auth.json}"

STORE_DIR="${AI_SWITCH_HOME}/credentials"
LEGACY_STORE_DIR="${CODEX_HOME}/credentials"
LEGACY_OPENCODE_DIR="${CODEX_HOME}/credentials/opencode-openai"

UNIFIED_FORMAT="unified-openai-auth"

TMP_FILES=()
cleanup() {
  local file
  for file in "${TMP_FILES[@]}"; do
    [[ -n "${file}" && -f "${file}" ]] && rm -f "${file}"
  done
}
trap cleanup EXIT

new_tmp() {
  local file
  file="$(mktemp)"
  TMP_FILES+=("${file}")
  echo "${file}"
}

usage() {
  cat <<'EOF'
Usage:
  ai ls
  ai list
  ai save <account>
  ai use <account>
  ai usage
  ai delete <account>
  ai --platform codex list|save|use <account>
  ai --platform opencode list|save|use <account>

Description:
  ls                Show active account per platform (Codex/OpenCode)
  list              List saved accounts in the shared store
  save <account>    Save auth from the selected platform(s)
  use <account>     Switch the selected platform(s) to a saved account
  usage             Show Codex usage limits (same output as c-stat)
  delete <account>  Remove a saved account from the shared store

Notes:
  - Without --platform, save/use apply to all available platforms.
  - Saved accounts are stored once and can be used for both platforms.
  - Missing platforms are skipped unless explicitly requested.
  - Default store: ~/.local/share/ai-switch/credentials (override with AI_SWITCH_HOME).
  - Codex home defaults to ~/.codex (override with CODEX_HOME).
  - The usage command requires codex CLI and tmux.

Examples:
  ai ls
  ai list
  ai save work
  ai use personal
  ai usage
  ai delete personal
  ai --platform codex save work
  ai --platform opencode use personal
EOF
}

fail() {
  echo "Error: $*" >&2
  exit 1
}

warn() {
  echo "Warning: $*" >&2
}

ensure_deps() {
  command -v jq >/dev/null 2>&1 || fail "jq is required but not installed."
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

ensure_dirs() {
  mkdir -p "${STORE_DIR}"
}

validate_account_name() {
  local account="$1"
  [[ "${account}" =~ ^[A-Za-z0-9._-]+$ ]] || fail "Invalid account name '${account}'. Allowed: A-Z a-z 0-9 . _ -"
}

validate_platform() {
  local platform="$1"
  case "${platform}" in
    codex|opencode|all) ;;
    *) fail "Invalid platform '${platform}'. Use codex, opencode, or all." ;;
  esac
}

platform_label() {
  case "$1" in
    codex) echo "Codex" ;;
    opencode) echo "OpenCode" ;;
    all) echo "All platforms" ;;
  esac
}

platform_available() {
  case "$1" in
    codex) [[ -f "${CODEX_AUTH_FILE}" ]] ;;
    opencode) [[ -f "${OPENCODE_AUTH_FILE}" ]] ;;
    *) return 1 ;;
  esac
}

validate_codex_auth_file() {
  local file="$1"
  [[ -f "${file}" ]] || fail "Codex auth file not found at ${file}."
  jq -e 'type == "object" and has("auth_mode") and has("tokens")' "${file}" >/dev/null \
    || fail "Invalid Codex auth JSON in ${file}."
  jq -e '.tokens | has("access_token") and has("refresh_token") and has("account_id")' "${file}" >/dev/null \
    || fail "Codex auth tokens missing required fields in ${file}."
}

validate_opencode_auth_file() {
  local file="$1"
  [[ -f "${file}" ]] || fail "OpenCode auth file not found at ${file}."
  jq -e 'type == "object" and has("openai") and (.openai | type == "object")' "${file}" >/dev/null \
    || fail "Invalid OpenCode auth JSON in ${file}."
  jq -e '.openai | has("access") and has("refresh") and has("accountId")' "${file}" >/dev/null \
    || fail "OpenCode auth .openai section is missing required fields in ${file}."
}

validate_openai_object_file() {
  local file="$1"
  [[ -f "${file}" ]] || fail "Account file not found: ${file}."
  jq -e 'type == "object" and has("access") and has("refresh") and has("accountId")' "${file}" >/dev/null \
    || fail "Invalid OpenCode account JSON in ${file}."
}

build_unified_from_codex_file() {
  local file="$1"
  local tokens_json
  local auth_mode
  local openai_api_key
  local last_refresh
  local updated_at

  validate_codex_auth_file "${file}"

  tokens_json="$(jq -c '.tokens' "${file}")"
  auth_mode="$(jq -r '.auth_mode // "chatgpt"' "${file}")"
  openai_api_key="$(jq -c '.OPENAI_API_KEY' "${file}")"
  last_refresh="$(jq -r '.last_refresh // ""' "${file}")"
  updated_at="$(now_utc)"

  jq -n \
    --arg format "${UNIFIED_FORMAT}" \
    --arg updated_at "${updated_at}" \
    --arg auth_mode "${auth_mode}" \
    --arg last_refresh "${last_refresh}" \
    --argjson openai_api_key "${openai_api_key}" \
    --argjson tokens "${tokens_json}" \
    '{
      format: $format,
      version: 1,
      updated_at: $updated_at,
      source: "codex",
      tokens: ($tokens + {id_token: ($tokens.id_token // null)}),
      opencode: { expires: null, type: null },
      codex: {
        auth_mode: $auth_mode,
        openai_api_key: $openai_api_key,
        last_refresh: (if $last_refresh == "" then null else $last_refresh end)
      }
    }'
}

build_unified_from_openai_json() {
  local openai_json="$1"
  local updated_at

  updated_at="$(now_utc)"

  jq -n \
    --arg format "${UNIFIED_FORMAT}" \
    --arg updated_at "${updated_at}" \
    --argjson openai "${openai_json}" \
    '{
      format: $format,
      version: 1,
      updated_at: $updated_at,
      source: "opencode",
      tokens: {
        access_token: $openai.access,
        refresh_token: $openai.refresh,
        account_id: $openai.accountId,
        id_token: null
      },
      opencode: {
        expires: ($openai.expires // null),
        type: ($openai.type // null)
      },
      codex: {
        auth_mode: "chatgpt",
        openai_api_key: null,
        last_refresh: null
      }
    }'
}

build_unified_from_openai_object_file() {
  local file="$1"
  local openai_json

  validate_openai_object_file "${file}"
  openai_json="$(jq -c '.' "${file}")"
  build_unified_from_openai_json "${openai_json}"
}

build_unified_from_opencode_auth_file() {
  local file="$1"
  local openai_json

  validate_opencode_auth_file "${file}"
  openai_json="$(jq -c '.openai' "${file}")"
  build_unified_from_openai_json "${openai_json}"
}

try_build_unified_from_codex_file() {
  local file="$1"
  local tokens_json
  local auth_mode
  local openai_api_key
  local last_refresh
  local updated_at

  if ! jq -e 'type == "object" and has("auth_mode") and has("tokens") and (.tokens | has("access_token") and has("refresh_token") and has("account_id"))' "${file}" >/dev/null 2>&1; then
    return 1
  fi

  tokens_json="$(jq -c '.tokens' "${file}" 2>/dev/null)" || return 1
  auth_mode="$(jq -r '.auth_mode // "chatgpt"' "${file}" 2>/dev/null)" || return 1
  openai_api_key="$(jq -c '.OPENAI_API_KEY' "${file}" 2>/dev/null)" || return 1
  last_refresh="$(jq -r '.last_refresh // ""' "${file}" 2>/dev/null)" || return 1
  updated_at="$(now_utc)"

  jq -n \
    --arg format "${UNIFIED_FORMAT}" \
    --arg updated_at "${updated_at}" \
    --arg auth_mode "${auth_mode}" \
    --arg last_refresh "${last_refresh}" \
    --argjson openai_api_key "${openai_api_key}" \
    --argjson tokens "${tokens_json}" \
    '{
      format: $format,
      version: 1,
      updated_at: $updated_at,
      source: "codex",
      tokens: ($tokens + {id_token: ($tokens.id_token // null)}),
      opencode: { expires: null, type: null },
      codex: {
        auth_mode: $auth_mode,
        openai_api_key: $openai_api_key,
        last_refresh: (if $last_refresh == "" then null else $last_refresh end)
      }
    }'
}

try_build_unified_from_openai_object_file() {
  local file="$1"
  local openai_json

  if ! jq -e 'type == "object" and has("access") and has("refresh") and has("accountId")' "${file}" >/dev/null 2>&1; then
    return 1
  fi

  openai_json="$(jq -c '.' "${file}" 2>/dev/null)" || return 1
  build_unified_from_openai_json "${openai_json}"
}

normalize_saved_file() {
  local file="$1"

  if jq -e ".format == \"${UNIFIED_FORMAT}\"" "${file}" >/dev/null 2>&1; then
    cat "${file}"
    return 0
  fi

  if jq -e 'has("auth_mode") and has("tokens")' "${file}" >/dev/null 2>&1; then
    build_unified_from_codex_file "${file}"
    return 0
  fi

  if jq -e 'has("access") and has("accountId")' "${file}" >/dev/null 2>&1; then
    build_unified_from_openai_object_file "${file}"
    return 0
  fi

  return 1
}

normalize_saved_file_or_fail() {
  local file="$1"
  normalize_saved_file "${file}" || fail "Unsupported account format in ${file}."
}

merge_unified_files() {
  local existing="$1"
  local incoming="$2"

  jq -n --slurpfile existing "${existing}" --slurpfile incoming "${incoming}" '
    def pick(new; old):
      if new == null or new == "" then old else new end;
    $incoming[0] as $n | $existing[0] as $e |
    $n
    | .source = "mixed"
    | .tokens.id_token = pick(.tokens.id_token; $e.tokens.id_token)
    | .opencode.expires = pick(.opencode.expires; $e.opencode.expires)
    | .opencode.type = pick(.opencode.type; $e.opencode.type)
    | .codex.auth_mode = pick(.codex.auth_mode; $e.codex.auth_mode)
    | .codex.openai_api_key = (if .codex.openai_api_key == null then $e.codex.openai_api_key else .codex.openai_api_key end)
    | .codex.last_refresh = pick(.codex.last_refresh; $e.codex.last_refresh)
  '
}

check_unified_file() {
  local file="$1"
  jq -e --arg format "${UNIFIED_FORMAT}" '
    type == "object"
    and .format == $format
    and (.version == 1)
    and (.tokens | type == "object")
    and (.tokens.access_token | type == "string")
    and (.tokens.refresh_token | type == "string")
    and (.tokens.account_id | type == "string")
  ' "${file}" >/dev/null 2>&1
}

validate_unified_file() {
  local file="$1"
  check_unified_file "${file}" || fail "Invalid unified account file: ${file}."
}

account_id_from_saved_file() {
  local file="$1"
  local account_id=""

  if jq -e ".format == \"${UNIFIED_FORMAT}\"" "${file}" >/dev/null 2>&1; then
    account_id="$(jq -r '.tokens.account_id // empty' "${file}" 2>/dev/null || true)"
  elif jq -e 'has("auth_mode") and has("tokens")' "${file}" >/dev/null 2>&1; then
    account_id="$(jq -r '.tokens.account_id // empty' "${file}" 2>/dev/null || true)"
  elif jq -e 'has("access") and has("accountId")' "${file}" >/dev/null 2>&1; then
    account_id="$(jq -r '.accountId // empty' "${file}" 2>/dev/null || true)"
  fi

  echo "${account_id}"
}

list_accounts() {
  local files
  local file
  local name
  local any=0
  declare -A seen=()

  files=$(find "${STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    if [[ -z "${seen[${name}]+x}" ]]; then
      echo "${name}"
      seen["${name}"]=1
      any=1
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    if [[ -z "${seen[${name}]+x}" ]]; then
      echo "${name}"
      seen["${name}"]=1
      any=1
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_OPENCODE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    if [[ -z "${seen[${name}]+x}" ]]; then
      echo "${name}"
      seen["${name}"]=1
      any=1
    fi
  done <<< "${files}"

  if [[ "${any}" -eq 0 ]]; then
    echo "No saved accounts found in ${STORE_DIR} or legacy stores."
    return 0
  fi
}

find_account_name_by_account_id() {
  local account_id="$1"
  local file
  local saved_account_id
  local files

  files=$(find "${STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    saved_account_id="$(account_id_from_saved_file "${file}")"
    if [[ -n "${saved_account_id}" && "${saved_account_id}" == "${account_id}" ]]; then
      basename "${file}" .json
      return 0
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    saved_account_id="$(account_id_from_saved_file "${file}")"
    if [[ -n "${saved_account_id}" && "${saved_account_id}" == "${account_id}" ]]; then
      basename "${file}" .json
      return 0
    fi
  done <<< "${files}"

  files=$(find "${LEGACY_OPENCODE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    saved_account_id="$(account_id_from_saved_file "${file}")"
    if [[ -n "${saved_account_id}" && "${saved_account_id}" == "${account_id}" ]]; then
      basename "${file}" .json
      return 0
    fi
  done <<< "${files}"

  return 1
}

active_account_for_platform() {
  local platform="$1"
  local account_id=""
  local match=""

  case "${platform}" in
    codex)
      if [[ ! -f "${CODEX_AUTH_FILE}" ]]; then
        echo "not configured"
        return 0
      fi
      account_id="$(jq -r '.tokens.account_id // empty' "${CODEX_AUTH_FILE}" 2>/dev/null || true)"
      ;;
    opencode)
      if [[ ! -f "${OPENCODE_AUTH_FILE}" ]]; then
        echo "not configured"
        return 0
      fi
      account_id="$(jq -r '.openai.accountId // empty' "${OPENCODE_AUTH_FILE}" 2>/dev/null || true)"
      ;;
    *)
      echo "unknown"
      return 0
      ;;
  esac

  if [[ -z "${account_id}" ]]; then
    echo "unknown"
    return 0
  fi

  if match="$(find_account_name_by_account_id "${account_id}" 2>/dev/null)"; then
    echo "${match}"
    return 0
  fi

  echo "unknown"
}

list_active_profiles() {
  local codex_active
  local opencode_active

  codex_active="$(active_account_for_platform codex)"
  opencode_active="$(active_account_for_platform opencode)"

  echo "Active accounts:"
  echo "  Codex: ${codex_active}"
  echo "  OpenCode: ${opencode_active}"
}

show_usage_limits() {
  local session="codex-status"
  local output

  if ! command -v tmux >/dev/null 2>&1; then
    warn "tmux is required for 'ai usage'."
    return 1
  fi

  if ! command -v codex >/dev/null 2>&1; then
    warn "codex CLI is required for 'ai usage'."
    return 1
  fi

  tmux kill-session -t "$session" 2>/dev/null || true
  if ! tmux new-session -d -s "$session"; then
    warn "Failed to create tmux session '${session}'."
    return 1
  fi

  tmux send-keys -t "$session" "codex" C-m
  sleep 5
  tmux send-keys -t "$session" "/status" C-m
  sleep 2

  output="$(
    tmux capture-pane -t "$session" -p -S -200 \
    | tr -d '\r' \
    | grep -Eo '[0-9]+h [0-9]+%|weekly [0-9]+%' \
    | paste -sd ' · ' -
  )"

  tmux kill-session -t "$session" 2>/dev/null || true

  if [[ -n "$output" ]]; then
    echo "$output"
  else
    warn "Could not parse Codex limits."
    return 1
  fi
}

migrate_legacy_store() {
  local files
  local file
  local name
  local has_any=0
  local migrated_any=0
  local backup_root
  declare -A accounts=()

  files=$(find "${LEGACY_STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    accounts["${name}"]=1
    has_any=1
  done <<< "${files}"

  files=$(find "${LEGACY_OPENCODE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    accounts["${name}"]=1
    has_any=1
  done <<< "${files}"

  if [[ "${has_any}" -eq 0 ]]; then
    return 0
  fi

  backup_root="${AI_SWITCH_HOME}/legacy-backup-$(date +%Y%m%d-%H%M%S)"
  mkdir -p "${backup_root}/codex" "${backup_root}/opencode"

  for name in "${!accounts[@]}"; do
    local codex_file="${LEGACY_STORE_DIR}/${name}.json"
    local opencode_file="${LEGACY_OPENCODE_DIR}/${name}.json"
    local base_tmp=""
    local tmp
    local merged
    local target="${STORE_DIR}/${name}.json"

    if [[ -f "${codex_file}" ]]; then
      tmp="$(new_tmp)"
      if try_build_unified_from_codex_file "${codex_file}" > "${tmp}"; then
        base_tmp="${tmp}"
      else
        warn "Skipping legacy Codex account '${name}' due to unsupported format: ${codex_file}"
      fi
    fi

    if [[ -f "${opencode_file}" ]]; then
      tmp="$(new_tmp)"
      if try_build_unified_from_openai_object_file "${opencode_file}" > "${tmp}"; then
        if [[ -n "${base_tmp}" ]]; then
          merged="$(new_tmp)"
          merge_unified_files "${base_tmp}" "${tmp}" > "${merged}"
          base_tmp="${merged}"
        else
          base_tmp="${tmp}"
        fi
      else
        warn "Skipping legacy OpenCode account '${name}' due to unsupported format: ${opencode_file}"
      fi
    fi

    if [[ -z "${base_tmp}" ]]; then
      continue
    fi

    if ! check_unified_file "${base_tmp}"; then
      warn "Skipping legacy account '${name}' due to invalid unified data."
      continue
    fi

    ensure_dirs
    if [[ ! -f "${target}" ]]; then
      mv "${base_tmp}" "${target}"
      chmod 600 "${target}" || true
    fi

    if [[ -f "${codex_file}" ]]; then
      mv "${codex_file}" "${backup_root}/codex/${name}.json"
      migrated_any=1
    fi

    if [[ -f "${opencode_file}" ]]; then
      mv "${opencode_file}" "${backup_root}/opencode/${name}.json"
      migrated_any=1
    fi
  done

  rmdir "${LEGACY_OPENCODE_DIR}" 2>/dev/null || true
  rmdir "${LEGACY_STORE_DIR}" 2>/dev/null || true

  if [[ "${migrated_any}" -eq 1 ]]; then
    warn "Legacy credentials moved to ${backup_root}"
  fi
}

prepare_account_entry() {
  local account="$1"
  local primary="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local source=""
  local normalized
  local needs_migration=0

  if [[ -f "${primary}" ]]; then
    source="${primary}"
  elif [[ -f "${legacy_store}" ]]; then
    source="${legacy_store}"
  elif [[ -f "${legacy_opencode}" ]]; then
    source="${legacy_opencode}"
  else
    fail "Account not found: ${account}"
  fi

  normalized="$(new_tmp)"
  normalize_saved_file_or_fail "${source}" > "${normalized}"
  validate_unified_file "${normalized}"

  if [[ "${source}" != "${primary}" ]]; then
    needs_migration=1
  elif ! jq -e ".format == \"${UNIFIED_FORMAT}\"" "${source}" >/dev/null 2>&1; then
    needs_migration=1
  fi

  if [[ "${needs_migration}" -eq 1 ]]; then
    ensure_dirs
    cp "${normalized}" "${primary}"
    chmod 600 "${primary}" || true
    warn "Migrated legacy account to ${primary}"
  fi

  echo "${normalized}"
}

delete_account() {
  local account="$1"
  local primary="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local deleted=0

  if [[ -f "${primary}" ]]; then
    rm -f "${primary}"
    deleted=1
  fi

  if [[ -f "${legacy_store}" ]]; then
    rm -f "${legacy_store}"
    deleted=1
  fi

  if [[ -f "${legacy_opencode}" ]]; then
    rm -f "${legacy_opencode}"
    deleted=1
  fi

  if [[ "${deleted}" -eq 0 ]]; then
    fail "Account not found: ${account}"
  fi

  echo "Removed saved account '${account}' from the store."
}

save_account_platform() {
  local platform="$1"
  local account="$2"
  local target="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local new_file
  local existing_file
  local merged_file

  case "${platform}" in
    codex)
      new_file="$(new_tmp)"
      build_unified_from_codex_file "${CODEX_AUTH_FILE}" > "${new_file}"
      ;;
    opencode)
      new_file="$(new_tmp)"
      build_unified_from_opencode_auth_file "${OPENCODE_AUTH_FILE}" > "${new_file}"
      ;;
    *)
      fail "Unsupported platform '${platform}'."
      ;;
  esac

  if [[ -f "${target}" ]]; then
    existing_file="$(new_tmp)"
    normalize_saved_file_or_fail "${target}" > "${existing_file}"
    merged_file="$(new_tmp)"
    merge_unified_files "${existing_file}" "${new_file}" > "${merged_file}"
    new_file="${merged_file}"
  elif [[ -f "${legacy_store}" ]]; then
    existing_file="$(new_tmp)"
    normalize_saved_file_or_fail "${legacy_store}" > "${existing_file}"
    merged_file="$(new_tmp)"
    merge_unified_files "${existing_file}" "${new_file}" > "${merged_file}"
    new_file="${merged_file}"
  elif [[ -f "${legacy_opencode}" ]]; then
    existing_file="$(new_tmp)"
    normalize_saved_file_or_fail "${legacy_opencode}" > "${existing_file}"
    merged_file="$(new_tmp)"
    merge_unified_files "${existing_file}" "${new_file}" > "${merged_file}"
    new_file="${merged_file}"
  fi

  validate_unified_file "${new_file}"
  ensure_dirs
  mv "${new_file}" "${target}"
  chmod 600 "${target}" || true
  echo "Saved $(platform_label "${platform}") account '${account}' to ${target}"
}

save_account_all() {
  local account="$1"
  local did_any=0

  echo "Applying to all available platforms."

  if platform_available codex; then
    save_account_platform codex "${account}"
    did_any=1
  else
    warn "Codex auth file not found; skipping Codex."
  fi

  if platform_available opencode; then
    save_account_platform opencode "${account}"
    did_any=1
  else
    warn "OpenCode auth file not found; skipping OpenCode."
  fi

  if [[ "${did_any}" -eq 0 ]]; then
    fail "No platforms available to save."
  fi
}

build_codex_auth_from_unified() {
  local unified_file="$1"
  local updated_at

  updated_at="$(now_utc)"

  jq -n --arg updated_at "${updated_at}" --slurpfile u "${unified_file}" '
    $u[0] as $u |
    {
      OPENAI_API_KEY: $u.codex.openai_api_key,
      auth_mode: ($u.codex.auth_mode // "chatgpt"),
      last_refresh: (if ($u.codex.last_refresh // "") == "" then $updated_at else $u.codex.last_refresh end),
      tokens: {
        access_token: $u.tokens.access_token,
        refresh_token: $u.tokens.refresh_token,
        account_id: $u.tokens.account_id,
        id_token: ($u.tokens.id_token // null)
      }
    }
  '
}

build_openai_object_from_unified() {
  local unified_file="$1"

  jq -n --slurpfile u "${unified_file}" '
    $u[0] as $u |
    {
      access: $u.tokens.access_token,
      refresh: $u.tokens.refresh_token,
      accountId: $u.tokens.account_id,
      expires: ($u.opencode.expires // 0),
      type: ($u.opencode.type // "oauth")
    }
  '
}

use_account_codex() {
  local unified_file="$1"
  local account="$2"
  local active_auth_file="${CODEX_AUTH_FILE}"
  local tmp

  tmp="$(new_tmp)"
  build_codex_auth_from_unified "${unified_file}" > "${tmp}"

  if [[ -f "${active_auth_file}" ]]; then
    local existing_id_token
    existing_id_token="$(jq -r '.tokens.id_token // empty' "${active_auth_file}" 2>/dev/null || true)"
    if [[ -n "${existing_id_token}" ]]; then
      local merged_tmp
      merged_tmp="$(new_tmp)"
      jq --arg id_token "${existing_id_token}" \
        'if (.tokens.id_token == null or .tokens.id_token == "") then .tokens.id_token = $id_token else . end' \
        "${tmp}" > "${merged_tmp}"
      tmp="${merged_tmp}"
    fi

  else
    echo "Codex auth file does not exist yet, creating a new one."
  fi

  mv "${tmp}" "${active_auth_file}"
  chmod 600 "${active_auth_file}" || true
  echo "Active Codex auth switched to account '${account}'"
}

use_account_opencode() {
  local unified_file="$1"
  local account="$2"
  local active_auth_file="${OPENCODE_AUTH_FILE}"
  local openai_tmp
  local tmp
  local openai_json

  if [[ ! -f "${active_auth_file}" ]]; then
    fail "OpenCode auth file not found at ${active_auth_file}. Run 'opencode auth login' first."
  fi

  openai_tmp="$(new_tmp)"
  build_openai_object_from_unified "${unified_file}" > "${openai_tmp}"
  if [[ -f "${active_auth_file}" ]]; then
    local existing_openai
    local merged_openai
    existing_openai="$(jq -c '.openai // {}' "${active_auth_file}" 2>/dev/null || echo '{}')"
    merged_openai="$(new_tmp)"
    jq --argjson existing "${existing_openai}" '
      .expires = (if (.expires == 0 or .expires == null) and ($existing.expires != null) then $existing.expires else .expires end)
      | .type = (if (.type == "oauth" or .type == null) and ($existing.type != null) then $existing.type else .type end)
    ' "${openai_tmp}" > "${merged_openai}"
    openai_tmp="${merged_openai}"
  fi

  openai_json="$(cat "${openai_tmp}")"

  tmp="$(new_tmp)"
  jq --argjson openai "${openai_json}" '.openai = $openai' "${active_auth_file}" > "${tmp}"
  mv "${tmp}" "${active_auth_file}"
  chmod 600 "${active_auth_file}" || true
  echo "Active OpenCode auth switched to account '${account}'"
}

use_account_platform() {
  local platform="$1"
  local account="$2"
  local unified_file

  unified_file="$(prepare_account_entry "${account}")"

  case "${platform}" in
    codex) use_account_codex "${unified_file}" "${account}" ;;
    opencode) use_account_opencode "${unified_file}" "${account}" ;;
    *) fail "Unsupported platform '${platform}'." ;;
  esac
}

use_account_all() {
  local account="$1"
  local unified_file
  local did_any=0

  echo "Applying to all available platforms."

  unified_file="$(prepare_account_entry "${account}")"

  if platform_available codex; then
    use_account_codex "${unified_file}" "${account}"
    did_any=1
  else
    warn "Codex auth file not found; skipping Codex."
  fi

  if platform_available opencode; then
    use_account_opencode "${unified_file}" "${account}"
    did_any=1
  else
    warn "OpenCode auth file not found; skipping OpenCode."
  fi

  if [[ "${did_any}" -eq 0 ]]; then
    fail "No platforms available to switch."
  fi
}

parse_args() {
  local platform=""
  local command=""

  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  if [[ $# -ge 1 && "$1" == "ls" ]]; then
    shift
    [[ $# -eq 0 ]] || fail "Unexpected arguments for 'ls'."
    list_active_profiles
    return 0
  fi

  while (( $# )); do
    case "$1" in
      -h|--help|help)
        usage
        exit 0
        ;;
      -p|--platform)
        [[ $# -ge 2 ]] || fail "Missing value for --platform."
        platform="$2"
        shift 2
        ;;
      --platform=*)
        platform="${1#*=}"
        shift
        ;;
      list|save|use|usage|delete)
        command="$1"
        shift
        break
        ;;
      --)
        shift
        break
        ;;
      -*)
        fail "Unknown option '${1}'."
        ;;
      *)
        fail "Expected command list/save/use/usage/delete after options."
        ;;
    esac
  done

  [[ -n "${command}" ]] || fail "Missing command. Use list, save, use, usage, or delete."

  if [[ -n "${platform}" ]]; then
    validate_platform "${platform}"
  else
    platform="all"
  fi

  case "${command}" in
    usage)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'usage'."
      show_usage_limits
      ;;
    list)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'list'."
      list_accounts
      ;;
    save)
      [[ $# -eq 1 ]] || fail "Usage: ai ${platform:+--platform ${platform} }save <account>"
      validate_account_name "$1"
      if [[ "${platform}" == "all" ]]; then
        save_account_all "$1"
      else
        if ! platform_available "${platform}"; then
          fail "$(platform_label "${platform}") auth file not found; cannot save."
        fi
        save_account_platform "${platform}" "$1"
      fi
      ;;
    use)
      [[ $# -eq 1 ]] || fail "Usage: ai ${platform:+--platform ${platform} }use <account>"
      validate_account_name "$1"
      if [[ "${platform}" == "all" ]]; then
        use_account_all "$1"
      else
        if ! platform_available "${platform}"; then
          fail "$(platform_label "${platform}") auth file not found; cannot switch."
        fi
        use_account_platform "${platform}" "$1"
      fi
      ;;
    delete)
      [[ $# -eq 1 ]] || fail "Usage: ai delete <account>"
      validate_account_name "$1"
      delete_account "$1"
      ;;
    *)
      fail "Unknown command '${command}'."
      ;;
  esac
}

main() {
  ensure_deps
  ensure_dirs
  migrate_legacy_store
  parse_args "$@"
}

main "$@"
