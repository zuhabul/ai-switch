run_managed_codex() {
  local original_args=("$@")
  local resume_global_args=()
  local known_resume_target=""
  local pending_resume_line=""
  local preferred_account=""
  local active_account=""
  local next_account=""
  local session_id=""
  local session_file=""
  local preferred_session_lookup=""
  local stamp_file
  local log_file
  local exit_code
  local cooldown_seconds
  local cooldown_until
  local attempt=0
  local started_at
  local cmd=()
  local arg

  if ! command -v "${AI_SWITCH_CODEX_BIN}" >/dev/null 2>&1; then
    fail "Codex CLI not found: ${AI_SWITCH_CODEX_BIN}"
  fi

  if seamless_proxy_ready; then
    run_seamless_codex_passthrough "${original_args[@]}"
  fi

  for arg in "${original_args[@]}"; do
    case "${arg}" in
      -h|--help|-V|--version)
        run_unmanaged_codex_passthrough "${original_args[@]}"
        ;;
    esac
  done

  if ! is_managed_codex_supported_args "${original_args[@]}"; then
    run_unmanaged_codex_passthrough "${original_args[@]}"
  fi

  require_codex_file_auth
  ensure_codex_pool_file
  ensure_codex_session_state_file
  if [[ "$(jq '.accounts | length' "${CODEX_POOL_FILE}")" -eq 0 ]] && [[ "$(saved_account_count)" -ge 2 ]]; then
    pool_sync_saved_accounts >/dev/null
    echo "Initialized Codex rotation pool from saved accounts."
  fi

  while IFS= read -r line; do
    [[ -z "${line}" ]] || resume_global_args+=("${line}")
  done < <(extract_resume_global_args "${original_args[@]}")
  known_resume_target="$(extract_resume_target "${original_args[@]}")"

  if [[ -z "${known_resume_target}" ]]; then
    pending_resume_line="$(resolve_pending_managed_codex_resume "${PWD}" || true)"
    if [[ -n "${pending_resume_line}" ]]; then
      known_resume_target="${pending_resume_line%%$'\t'*}"
      preferred_account="${pending_resume_line#*$'\t'}"
      echo "Resuming interrupted managed Codex session '${known_resume_target}'."
    fi
  fi

  if [[ -n "${preferred_account}" ]] && pool_account_available "${preferred_account}"; then
    active_account="${preferred_account}"
  else
    active_account="$(pool_next_account)" || fail "No available Codex accounts in the rotation pool. Configure one with 'ai pool-set <account> [...]'."
  fi
  pool_mark_selected "${active_account}"
  use_account_platform codex "${active_account}" >/dev/null
  echo "Starting managed Codex with account '${active_account}'."

  while :; do
    attempt=$((attempt + 1))
    stamp_file="$(new_tmp)"
    : > "${stamp_file}"
    started_at="$(date +%s)"
    log_file="${CODEX_LOG_DIR}/codex-run-${started_at}-${attempt}.log"

    if [[ -n "${session_id}" ]]; then
      cmd=("${AI_SWITCH_CODEX_BIN}" "${resume_global_args[@]}" resume "${session_id}")
    elif [[ "${known_resume_target}" == "__LAST__" ]]; then
      cmd=("${AI_SWITCH_CODEX_BIN}" "${resume_global_args[@]}" resume --last)
    elif [[ -n "${known_resume_target}" ]]; then
      cmd=("${AI_SWITCH_CODEX_BIN}" "${resume_global_args[@]}" resume "${known_resume_target}")
    else
      cmd=("${AI_SWITCH_CODEX_BIN}" "${original_args[@]}")
    fi

    # Trap SIGINT so the wrapper survives if the user Ctrl+C's out of a hung Codex
    trap ':' INT
    if run_codex_command "${log_file}" "${cmd[@]}"; then
      exit_code=0
    else
      exit_code=$?
    fi
    trap - INT

    preferred_session_lookup="${session_id}"
    if [[ -z "${preferred_session_lookup}" && -n "${known_resume_target}" && "${known_resume_target}" != "__LAST__" ]]; then
      preferred_session_lookup="${known_resume_target}"
    fi
    session_file="$(detect_recent_session_file "${stamp_file}" "${PWD}" "${preferred_session_lookup}" || true)"
    if [[ -z "${session_id}" ]]; then
      if [[ -n "${session_file}" ]]; then
        session_id="$(extract_session_id_from_file "${session_file}" || true)"
      fi
      if [[ -z "${session_id}" ]]; then
        session_id="$(detect_session_id_from_log "${log_file}" || true)"
      fi
      if [[ -z "${session_id}" && "${known_resume_target}" == "__LAST__" ]]; then
        session_id="$(resolve_last_session_id || true)"
      elif [[ -z "${session_id}" && -n "${known_resume_target}" && "${known_resume_target}" != "__LAST__" ]]; then
        session_id="${known_resume_target}"
      fi
    fi
    if [[ -z "${session_file}" && -n "${session_id}" ]]; then
      session_file="$(find_session_file_by_id "${session_id}" || true)"
    fi
    if [[ -n "${session_file}" ]]; then
      cache_rate_limits_from_session_file "${active_account}" "${session_file}" "chatgpt-session" "${session_id}" || true
    fi
    if [[ -n "${session_id}" ]]; then
      update_managed_codex_session_state "${session_id}" "${session_file}" "${PWD}" "${active_account}" true "running"
    fi

    if ! codex_log_has_rate_limit "${log_file}"; then
      # If exited via SIGINT and usage is high, treat as a rate limit hang
      if [[ "${exit_code}" -eq 130 ]]; then
        local p_used
        p_used="$(jq -r --arg account "${active_account}" '.accounts[$account].primary.used_percent // 0' "${CODEX_LIMITS_FILE}" 2>/dev/null || echo 0)"
        local is_cooling
        is_cooling="$(jq -r --arg account "${active_account}" --arg now "$(date +%s)" 'if (.cooldowns[$account].until_epoch // 0) > ($now | tonumber) then 1 else 0 end' "${CODEX_POOL_FILE}" 2>/dev/null || echo 0)"
        
        if awk "BEGIN {exit !(${p_used} >= 90)}" || [[ "${is_cooling}" -eq 1 ]]; then
           echo "Ctrl+C detected during high usage (${p_used}%) or cooldown. Assuming rate limit hang."
           pool_mark_cooldown "${active_account}" "$(( $(date +%s) + DEFAULT_RATE_LIMIT_COOLDOWN_SECONDS ))" "rate_limited"
        else
           update_managed_codex_session_state "${session_id}" "${session_file}" "${PWD}" "${active_account}" true "sigint"
           generate_sync_file
           return "${exit_code}"
        fi
      else
        if [[ "${exit_code}" -eq 0 ]]; then
          update_managed_codex_session_state "${session_id}" "${session_file}" "${PWD}" "${active_account}" false "clean_exit"
        else
          update_managed_codex_session_state "${session_id}" "${session_file}" "${PWD}" "${active_account}" true "nonzero_exit"
        fi
        generate_sync_file
        return "${exit_code}"
      fi
    else
      cooldown_seconds="$(parse_rate_limit_cooldown_seconds "${log_file}")"
      cooldown_until=$(( $(date +%s) + cooldown_seconds ))
      pool_mark_cooldown "${active_account}" "${cooldown_until}" "rate_limited"
    fi

    next_account="$(pool_next_account "${active_account}" || true)"
    if [[ -z "${next_account}" ]]; then
      update_managed_codex_session_state "${session_id}" "${session_file}" "${PWD}" "${active_account}" true "rate_limited"
      generate_sync_file
      fail "Account '${active_account}' was rate limited, and no other pool account is currently available."
    fi

    if [[ -z "${session_id}" ]]; then
      fail "Account '${active_account}' was rate limited, but the current Codex session ID could not be determined for auto-resume."
    fi

    use_account_platform codex "${next_account}" >/dev/null
    pool_mark_selected "${next_account}"
    export AI_ACCOUNT="${next_account}"
    update_managed_codex_session_state "${session_id}" "${session_file}" "${PWD}" "${next_account}" true "rate_limited"
    generate_sync_file
    echo "Rate limit detected for '${active_account}'. Switched to '${next_account}' and resuming session '${session_id}'."
    active_account="${next_account}"
  done
}

migrate_legacy_store() {
  local files
  local file
  local name
  local has_any=0
  local migrated_any=0
  local backup_root
  declare -A accounts=()

  files=$(find "${LEGACY_STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    accounts["${name}"]=1
    has_any=1
  done <<< "${files}"

  files=$(find "${LEGACY_OPENCODE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | sort || true)
  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    name="$(basename "${file}" .json)"
    accounts["${name}"]=1
    has_any=1
  done <<< "${files}"

  if [[ "${has_any}" -eq 0 ]]; then
    return 0
  fi

  backup_root="${AI_SWITCH_HOME}/legacy-backup-$(date +%Y%m%d-%H%M%S)"
  mkdir -p "${backup_root}/codex" "${backup_root}/opencode"

  for name in "${!accounts[@]}"; do
    local codex_file="${LEGACY_STORE_DIR}/${name}.json"
    local opencode_file="${LEGACY_OPENCODE_DIR}/${name}.json"
    local base_tmp=""
    local tmp
    local merged
    local target="${STORE_DIR}/${name}.json"

    if [[ -f "${codex_file}" ]]; then
      tmp="$(new_tmp)"
      if try_build_unified_from_codex_file "${codex_file}" > "${tmp}"; then
        base_tmp="${tmp}"
      else
        warn "Skipping legacy Codex account '${name}' due to unsupported format: ${codex_file}"
      fi
    fi

    if [[ -f "${opencode_file}" ]]; then
      tmp="$(new_tmp)"
      if try_build_unified_from_openai_object_file "${opencode_file}" > "${tmp}"; then
        if [[ -n "${base_tmp}" ]]; then
          merged="$(new_tmp)"
          merge_unified_files "${base_tmp}" "${tmp}" > "${merged}"
          base_tmp="${merged}"
        else
          base_tmp="${tmp}"
        fi
      else
        warn "Skipping legacy OpenCode account '${name}' due to unsupported format: ${opencode_file}"
      fi
    fi

    if [[ -z "${base_tmp}" ]]; then
      continue
    fi

    if ! check_unified_file "${base_tmp}"; then
      warn "Skipping legacy account '${name}' due to invalid unified data."
      continue
    fi

    ensure_dirs
    if [[ ! -f "${target}" ]]; then
      mv "${base_tmp}" "${target}"
      chmod 600 "${target}" || true
    fi

    if [[ -f "${codex_file}" ]]; then
      mv "${codex_file}" "${backup_root}/codex/${name}.json"
      migrated_any=1
    fi

    if [[ -f "${opencode_file}" ]]; then
      mv "${opencode_file}" "${backup_root}/opencode/${name}.json"
      migrated_any=1
    fi
  done

  rmdir "${LEGACY_OPENCODE_DIR}" 2>/dev/null || true
  rmdir "${LEGACY_STORE_DIR}" 2>/dev/null || true

  if [[ "${migrated_any}" -eq 1 ]]; then
    warn "Legacy credentials moved to ${backup_root}"
  fi
}

prepare_account_entry() {
  local account="$1"
  local primary="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local source=""
  local normalized
  local needs_migration=0

  if [[ -f "${primary}" ]]; then
    source="${primary}"
  elif [[ -f "${legacy_store}" ]]; then
    source="${legacy_store}"
  elif [[ -f "${legacy_opencode}" ]]; then
    source="${legacy_opencode}"
  else
    fail "Account not found: ${account}"
  fi

  normalized="$(new_tmp)"
  normalize_saved_file_or_fail "${source}" > "${normalized}"
  validate_unified_file "${normalized}"

  if [[ "${source}" != "${primary}" ]]; then
    needs_migration=1
  elif ! jq -e ".format == \"${UNIFIED_FORMAT}\"" "${source}" >/dev/null 2>&1; then
    needs_migration=1
  fi

  if [[ "${needs_migration}" -eq 1 ]]; then
    ensure_dirs
    cp "${normalized}" "${primary}"
    chmod 600 "${primary}" || true
    warn "Migrated legacy account to ${primary}"
  fi

  echo "${normalized}"
}

delete_account() {
  local account="$1"
  local primary="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local deleted=0

  if [[ -f "${primary}" ]]; then
    rm -f "${primary}"
    deleted=1
  fi

  if [[ -f "${legacy_store}" ]]; then
    rm -f "${legacy_store}"
    deleted=1
  fi

  if [[ -f "${legacy_opencode}" ]]; then
    rm -f "${legacy_opencode}"
    deleted=1
  fi

  if [[ "${deleted}" -eq 0 ]]; then
    fail "Account not found: ${account}"
  fi

  echo "Removed saved account '${account}' from the store."
}

rename_account() {
  local old_account="$1"
  local new_account="$2"
  local old_file="${STORE_DIR}/${old_account}.json"
  local new_file="${STORE_DIR}/${new_account}.json"
  local tmp

  validate_account_name "${old_account}"
  validate_account_name "${new_account}"
  [[ "${old_account}" != "${new_account}" ]] || fail "Old and new account names are the same."

  prepare_account_entry "${old_account}" >/dev/null
  [[ -f "${old_file}" ]] || fail "Account not found: ${old_account}"
  [[ ! -f "${new_file}" ]] || fail "Target account already exists: ${new_account}"

  mv "${old_file}" "${new_file}"
  chmod 600 "${new_file}" || true

  ensure_codex_pool_file
  tmp="$(new_tmp)"
  jq --arg old "${old_account}" --arg new "${new_account}" --arg updated_at "$(now_utc)" '
    .accounts = [(.accounts // [])[] | if . == $old then $new else . end]
    | .cooldowns = ((.cooldowns // {}) | with_entries(.key |= if . == $old then $new else . end))
    | .last_account = (if .last_account == $old then $new else .last_account end)
    | .updated_at = $updated_at
  ' "${CODEX_POOL_FILE}" > "${tmp}"
  mv "${tmp}" "${CODEX_POOL_FILE}"
  chmod 600 "${CODEX_POOL_FILE}" || true

  echo "Renamed saved account '${old_account}' to '${new_account}'."
}

save_account_platform() {
  local platform="$1"
  local account="$2"
  local target="${STORE_DIR}/${account}.json"
  local legacy_store="${LEGACY_STORE_DIR}/${account}.json"
  local legacy_opencode="${LEGACY_OPENCODE_DIR}/${account}.json"
  local new_file
  local existing_file
  local merged_file

  case "${platform}" in
    codex)
      new_file="$(new_tmp)"
      build_unified_from_codex_file "${CODEX_AUTH_FILE}" > "${new_file}"
      ;;
    opencode)
      new_file="$(new_tmp)"
      build_unified_from_opencode_auth_file "${OPENCODE_AUTH_FILE}" > "${new_file}"
      ;;
    *)
      fail "Unsupported platform '${platform}'."
      ;;
  esac

  if [[ -f "${target}" ]]; then
    existing_file="$(new_tmp)"
    normalize_saved_file_or_fail "${target}" > "${existing_file}"
    merged_file="$(new_tmp)"
    merge_unified_files "${existing_file}" "${new_file}" > "${merged_file}"
    new_file="${merged_file}"
  elif [[ -f "${legacy_store}" ]]; then
    existing_file="$(new_tmp)"
    normalize_saved_file_or_fail "${legacy_store}" > "${existing_file}"
    merged_file="$(new_tmp)"
    merge_unified_files "${existing_file}" "${new_file}" > "${merged_file}"
    new_file="${merged_file}"
  elif [[ -f "${legacy_opencode}" ]]; then
    existing_file="$(new_tmp)"
    normalize_saved_file_or_fail "${legacy_opencode}" > "${existing_file}"
    merged_file="$(new_tmp)"
    merge_unified_files "${existing_file}" "${new_file}" > "${merged_file}"
    new_file="${merged_file}"
  fi

  validate_unified_file "${new_file}"
  ensure_dirs
  mv "${new_file}" "${target}"
  chmod 600 "${target}" || true
  echo "Saved $(platform_label "${platform}") account '${account}' to ${target}"
}

save_account_all() {
  local account="$1"
  local did_any=0

  echo "Applying to all available platforms."

  if platform_available codex; then
    save_account_platform codex "${account}"
    did_any=1
  else
    warn "Codex auth file not found; skipping Codex."
  fi

  if platform_available opencode; then
    save_account_platform opencode "${account}"
    did_any=1
  else
    warn "OpenCode auth file not found; skipping OpenCode."
  fi

  if [[ "${did_any}" -eq 0 ]]; then
    fail "No platforms available to save."
  fi
}

build_codex_auth_from_unified() {
  local unified_file="$1"
  local updated_at

  updated_at="$(now_utc)"

  jq -n --arg updated_at "${updated_at}" --slurpfile u "${unified_file}" '
    $u[0] as $u |
    {
      OPENAI_API_KEY: $u.codex.openai_api_key,
      auth_mode: ($u.codex.auth_mode // "chatgpt"),
      last_refresh: (if ($u.codex.last_refresh // "") == "" then $updated_at else $u.codex.last_refresh end),
      tokens: {
        access_token: $u.tokens.access_token,
        refresh_token: $u.tokens.refresh_token,
        account_id: $u.tokens.account_id,
        id_token: ($u.tokens.id_token // null)
      }
    }
  '
}

build_openai_object_from_unified() {
  local unified_file="$1"

  jq -n --slurpfile u "${unified_file}" '
    $u[0] as $u |
    {
      access: $u.tokens.access_token,
      refresh: $u.tokens.refresh_token,
      accountId: $u.tokens.account_id,
      expires: ($u.opencode.expires // 0),
      type: ($u.opencode.type // "oauth")
    }
  '
}

use_account_codex() {
  local unified_file="$1"
  local account="$2"
  local active_auth_file="${CODEX_AUTH_FILE}"
  local tmp

  tmp="$(new_tmp)"
  build_codex_auth_from_unified "${unified_file}" > "${tmp}"

  if [[ -f "${active_auth_file}" ]]; then
    local existing_id_token
    existing_id_token="$(jq -r '.tokens.id_token // empty' "${active_auth_file}" 2>/dev/null || true)"
    if [[ -n "${existing_id_token}" ]]; then
      local merged_tmp
      merged_tmp="$(new_tmp)"
      jq --arg id_token "${existing_id_token}" \
        'if (.tokens.id_token == null or .tokens.id_token == "") then .tokens.id_token = $id_token else . end' \
        "${tmp}" > "${merged_tmp}"
      tmp="${merged_tmp}"
    fi

  else
    echo "Codex auth file does not exist yet, creating a new one."
  fi

  mv "${tmp}" "${active_auth_file}"
  chmod 600 "${active_auth_file}" || true
  echo "Active Codex auth switched to account '${account}'"
}

use_account_opencode() {
  local unified_file="$1"
  local account="$2"
  local active_auth_file="${OPENCODE_AUTH_FILE}"
  local openai_tmp
  local tmp
  local openai_json

  if [[ ! -f "${active_auth_file}" ]]; then
    fail "OpenCode auth file not found at ${active_auth_file}. Run 'opencode auth login' first."
  fi

  openai_tmp="$(new_tmp)"
  build_openai_object_from_unified "${unified_file}" > "${openai_tmp}"
  if [[ -f "${active_auth_file}" ]]; then
    local existing_openai
    local merged_openai
    existing_openai="$(jq -c '.openai // {}' "${active_auth_file}" 2>/dev/null || echo '{}')"
    merged_openai="$(new_tmp)"
    jq --argjson existing "${existing_openai}" '
      .expires = (if (.expires == 0 or .expires == null) and ($existing.expires != null) then $existing.expires else .expires end)
      | .type = (if (.type == "oauth" or .type == null) and ($existing.type != null) then $existing.type else .type end)
    ' "${openai_tmp}" > "${merged_openai}"
    openai_tmp="${merged_openai}"
  fi

  openai_json="$(cat "${openai_tmp}")"

  tmp="$(new_tmp)"
  jq --argjson openai "${openai_json}" '.openai = $openai' "${active_auth_file}" > "${tmp}"
  mv "${tmp}" "${active_auth_file}"
  chmod 600 "${active_auth_file}" || true
  echo "Active OpenCode auth switched to account '${account}'"
}

use_account_platform() {
  local platform="$1"
  local account="$2"
  local unified_file

  unified_file="$(prepare_account_entry "${account}")"

  case "${platform}" in
    codex) use_account_codex "${unified_file}" "${account}" ;;
    opencode) use_account_opencode "${unified_file}" "${account}" ;;
    *) fail "Unsupported platform '${platform}'." ;;
  esac

  # Atomically update sync file after any platform switch
  generate_sync_file
}

use_account_all() {
  local account="$1"
  local unified_file
  local did_any=0

  echo "Applying to all available platforms."

  unified_file="$(prepare_account_entry "${account}")"

  if platform_available codex; then
    use_account_codex "${unified_file}" "${account}"
    did_any=1
  else
    warn "Codex auth file not found; skipping Codex."
  fi

  if platform_available opencode; then
    use_account_opencode "${unified_file}" "${account}"
    did_any=1
  else
    warn "OpenCode auth file not found; skipping OpenCode."
  fi

  if [[ "${did_any}" -eq 0 ]]; then
    fail "No platforms available to switch."
  fi
}

generate_sync_file() {
  local codex_active
  local session_id=""
  local pending_resume="0"
  codex_active="$(active_account_for_platform codex)"
  ensure_codex_session_state_file
  session_id="$(jq -r '.session_id // ""' "${CODEX_SESSION_STATE_FILE}")"
  if [[ "$(jq -r '.pending_resume // false' "${CODEX_SESSION_STATE_FILE}")" == "true" ]]; then
    pending_resume="1"
  fi
  cat > "${AI_SWITCH_HOME}/sync.sh" <<EOF
export AI_ACCOUNT='${codex_active}'
export AI_CODEX_SESSION='${session_id}'
export AI_CODEX_RESUME_PENDING='${pending_resume}'
EOF
}

run_watch() {
  local interval=300
  local daemon=0
  local arg

  while [[ $# -gt 0 ]]; do
    arg="$1"
    shift
    case "${arg}" in
      --interval)
        interval="$1"
        shift
        ;;
      --daemon)
        daemon=1
        ;;
      *)
        fail "Unknown argument for 'watch': ${arg}"
        ;;
    esac
  done

  if [[ "${daemon}" -eq 1 ]]; then
    nohup "$0" watch --interval "${interval}" > "${AI_SWITCH_HOME}/watch.log" 2>&1 &
    echo "AI watch daemon started (PID $!). Logs at ${AI_SWITCH_HOME}/watch.log"
    return 0
  fi

  echo "AI watch started (interval ${interval}s). Monitoring for rate limits..."
  while :; do
    local now_epoch
    now_epoch="$(date +%s)"
    local active
    active="$(active_account_for_platform codex)"
    
    # Check if active is cooling
    if jq -e --arg account "${active}" --arg now "${now_epoch}" '
      (.cooldowns[$account].until_epoch // 0) > ($now | tonumber)
    ' "${CODEX_POOL_FILE}" >/dev/null 2>&1; then
      echo "[$(date)] Active account '${active}' is cooling. Rotating..."
      rotate_best_account --no-refresh
    fi
    
    # Check if usage > 90%
    local p_used
    p_used="$(jq -r --arg account "${active}" '.accounts[$account].primary.used_percent // 0' "${CODEX_LIMITS_FILE}")"
    # bc may not be available, use awk
    if awk "BEGIN {exit !(${p_used} > 90)}"; then
        echo "[$(date)] Active account '${active}' usage is high (${p_used}%). Rotating..."
        rotate_best_account --refresh
    fi

    sleep "${interval}"
  done
}

show_sync() {
  local codex_active
  local session_id=""
  local pending_resume="0"
  codex_active="$(active_account_for_platform codex)"
  ensure_codex_session_state_file
  session_id="$(jq -r '.session_id // ""' "${CODEX_SESSION_STATE_FILE}")"
  if [[ "$(jq -r '.pending_resume // false' "${CODEX_SESSION_STATE_FILE}")" == "true" ]]; then
    pending_resume="1"
  fi
  echo "export AI_ACCOUNT='${codex_active}';"
  echo "export AI_CODEX_SESSION='${session_id}';"
  echo "export AI_CODEX_RESUME_PENDING='${pending_resume}';"
}

show_total() {
  local accounts=()
  while IFS= read -r account; do
    [[ -n "${account}" ]] && accounts+=("${account}")
  done < <(pool_list_accounts)

  if [[ "${#accounts[@]}" -eq 0 ]]; then
    fail "No accounts in the rotation pool."
  fi

  refresh_codex_limits_cache_for_accounts 0 0 "${accounts[@]}" || true

  local now_epoch
  now_epoch="$(date +%s)"
  local active_account
  active_account="$(active_account_for_platform codex)"
  local best_account
  best_account="$(select_best_ready_account "${now_epoch}" "${accounts[@]}" || true)"
  local maybe_proxy="inactive"
  if seamless_proxy_ready; then
    maybe_proxy="active"
  fi

  local py_script
  py_script=$(cat <<'EOF'
import json
import sys
import shutil
import re
import time

def colorize(code, text):
    if not sys.stdout.isatty(): return text
    return f"\033[{code}m{text}\033[0m"

def visible_len(text):
    return len(re.sub(r'\x1b\[[0-9;]*m', '', str(text)))

def smooth_bar(pct, width=30):
    blocks = [" ", "▏", "▎", "▍", "▌", "▋", "▊", "▉", "█"]
    if pct < 0: pct = 0
    if pct > 100: pct = 100
    total_eighths = int(round((pct / 100.0) * width * 8))
    full_blocks = total_eighths // 8
    remainder = total_eighths % 8
    bar = "█" * full_blocks
    if full_blocks < width:
        bar += blocks[remainder]
        bar += " " * (width - full_blocks - 1)
    return bar

def main():
    try:
        with open(sys.argv[1]) as f: pool_data = json.load(f)
    except: pool_data = {"accounts": [], "cooldowns": {}}
    try:
        with open(sys.argv[2]) as f: limits_data = json.load(f)
    except: limits_data = {"accounts": {}}
    
    accounts = sys.argv[3].split(",") if sys.argv[3] else []
    active = sys.argv[4]
    
    healthy, cooling = 0, 0
    sum_p, count_p = 0, 0
    sum_s, count_s = 0, 0
    
    def safe_get(obj, *keys, default=None):
        for key in keys:
            if not isinstance(obj, dict): return default
            obj = obj.get(key)
            if obj is None: return default
        return obj

    for acc in accounts:
        acc_data = limits_data.get("accounts", {}).get(acc)
        if not isinstance(acc_data, dict): acc_data = {}
        
        # Count cooling
        cooldown = safe_get(pool_data, "cooldowns", acc, "until_epoch", default=0)
        if int(cooldown or 0) > int(time.time()): cooling += 1
        else: healthy += 1
        
        p = safe_get(acc_data, "primary", "used_percent")
        if p is not None: sum_p += float(p); count_p += 1
        s = safe_get(acc_data, "secondary", "used_percent")
        if s is not None: sum_s += float(s); count_s += 1

    avg_p = sum_p / count_p if count_p > 0 else 0
    avg_s = sum_s / count_s if count_s > 0 else 0
    avail_p = (100 - avg_p) * count_p / 100.0
    avail_s = (100 - avg_s) * count_s / 100.0
    
    term_width = shutil.get_terminal_size((80, 20)).columns
    box_w = min(term_width - 4, 70)
    
    print("")
    print(colorize("1;34", "┏" + "━"*box_w + "┓"))
    title = " 📊 GLOBAL POOL SUMMARY "
    print(colorize("1;34", "┃") + colorize("1;37;44", title.center(box_w)) + colorize("1;34", "┃"))
    print(colorize("1;34", "┣" + "━"*box_w + "┫"))
    
    def row(label, val):
        l = f" {label}:"
        v = f"{val} "
        return colorize("1;34", "┃") + colorize("37", l) + " " * (box_w - len(l) - len(v)) + colorize("1;32", v) + colorize("1;34", "┃")

    print(row("Total Accounts", len(accounts)))
    print(row("Ready Status", f"{healthy} active / {cooling} cooling"))
    print(row("Current Active", active))
    print(colorize("1;34", "┣" + "━"*box_w + "┫"))
    
    def bar_row(label, pct, avail):
        label_line = f" {label} UTILIZATION ({int(pct)}%)"
        print(colorize("1;34", "┃") + colorize("1;37", label_line.ljust(box_w)) + colorize("1;34", "┃"))
        bar = smooth_bar(pct, box_w - 4)
        color = "31" if pct > 90 else "33" if pct > 70 else "32"
        bar_view = colorize(color, f"  [{bar.replace(' ', '·')}]  ")
        print(colorize("1;34", "┃") + bar_view + colorize("1;34", "┃"))
        avail_line = f" Capacity Available: {avail:.1f} Full Units"
        print(colorize("1;34", "┃") + colorize("90", avail_line.ljust(box_w)) + colorize("1;34", "┃"))

    bar_row("5H PRIMARY", avg_p, avail_p)
    print(colorize("1;34", "┃") + " "*box_w + colorize("1;34", "┃"))
    bar_row("7D SECONDARY", avg_s, avail_s)
    
    print(colorize("1;34", "┗" + "━"*box_w + "┛"))
    print("")

if __name__ == "__main__": main()
EOF
)
  python3 -c "${py_script}" "${CODEX_POOL_FILE}" "${CODEX_LIMITS_FILE}" "$(IFS=,; echo "${accounts[*]}")" "${active_account}"
}

parse_args() {
  local platform=""
  local command=""

  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  if [[ $# -ge 1 && "$1" == "ls" ]]; then
    shift
    [[ $# -eq 0 ]] || fail "Unexpected arguments for 'ls'."
    list_active_profiles
    return 0
  fi

  while (( $# )); do
    case "$1" in
      -h|--help|help)
        usage
        exit 0
        ;;
      -p|--platform)
        [[ $# -ge 2 ]] || fail "Missing value for --platform."
        platform="$2"
        shift 2
        ;;
      --platform=*)
        platform="${1#*=}"
        shift
        ;;
      list|save|use|usage|status|rotate|delete|rename|pool-list|pool-set|pool-sync|pool-add|pool-remove|pool-cooldown|pool-reset-cooldowns|pool-status|total|codex|doctor|test-rotation|codex-wrapper-status|codex-install-wrapper|codex-uninstall-wrapper|sync|watch|setup-sync|install-sync)
        command="$1"
        shift
        break
        ;;
      --)
        shift
        break
        ;;
      -*)
        fail "Unknown option '${1}'."
        ;;
      *)
        fail "Expected a valid ai command after options."
        ;;
    esac
  done

  [[ -n "${command}" ]] || fail "Missing command. Use --help to see available ai commands."

  if [[ -n "${platform}" ]]; then
    validate_platform "${platform}"
  else
    platform="all"
  fi

  case "${command}" in
    usage)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'usage'."
      show_usage_limits
      ;;
    status)
      show_status "$@"
      ;;
    rotate)
      rotate_best_account "$@"
      ;;
    total)
      show_total
      ;;
    watch)
      run_watch "$@"
      ;;
    sync)
      show_sync
      ;;
    setup-sync)
      echo "To permanently sync ai-switch with your shell (including background rotations), add this to your ~/.bashrc or ~/.zshrc:"
      echo ""
      echo "  # ai-switch automatic sync"
      echo "  _ai_sync_hook() { [[ -f \"${AI_SWITCH_HOME}/sync.sh\" ]] && source \"${AI_SWITCH_HOME}/sync.sh\"; }"
      echo "  if [[ -n \"\$ZSH_VERSION\" ]]; then"
      echo "    autoload -Uz add-zsh-hook && add-zsh-hook precmd _ai_sync_hook"
      echo "  elif [[ -n \"\$BASH_VERSION\" ]]; then"
      echo "    PROMPT_COMMAND=\"_ai_sync_hook; \${PROMPT_COMMAND:-}\""
      echo "  fi"
      echo ""
      echo "Or simply run: ai install-sync"
      ;;
    install-sync)
      local hook_block
      hook_block=$(cat <<EOF

# ai-switch: Ultra-Reliable Shell Sync
ai() {
  # Sync environment before execution
  [[ -f "${AI_SWITCH_HOME}/sync.sh" ]] && . "${AI_SWITCH_HOME}/sync.sh"
  command ai "\$@"
  local ret=\$?
  # Sync environment after execution (to catch rotations)
  [[ -f "${AI_SWITCH_HOME}/sync.sh" ]] && . "${AI_SWITCH_HOME}/sync.sh"
  return \$ret
}
codex() {
  # Keep the calling shell in sync around every managed Codex run.
  [[ -f "${AI_SWITCH_HOME}/sync.sh" ]] && . "${AI_SWITCH_HOME}/sync.sh"
  command codex "\$@"
  local ret=\$?
  [[ -f "${AI_SWITCH_HOME}/sync.sh" ]] && . "${AI_SWITCH_HOME}/sync.sh"
  return \$ret
}
# Background sync hook for prompt refresh
_ai_prompt_sync() { [[ -f "${AI_SWITCH_HOME}/sync.sh" ]] && . "${AI_SWITCH_HOME}/sync.sh"; }
if [[ -n "\$ZSH_VERSION" ]]; then
  autoload -Uz add-zsh-hook && add-zsh-hook precmd _ai_prompt_sync
elif [[ -n "\$BASH_VERSION" ]]; then
  case "\$PROMPT_COMMAND" in
    *_ai_prompt_sync*) ;;
    *) PROMPT_COMMAND="_ai_prompt_sync; \${PROMPT_COMMAND:-}" ;;
  esac
fi
EOF
)
      local updated=0
      for f in "${HOME}/.bashrc" "${HOME}/.zshrc"; do
        if [[ -f "${f}" ]]; then
          # Clean up old versions first
          sed -i '/ai-switch automatic sync hook/d' "${f}" 2>/dev/null || true
          sed -i '/_ai_sync_hook/d' "${f}" 2>/dev/null || true
          
          if grep -q "ai-switch: Ultra-Reliable Shell Sync" "${f}"; then
            echo "Sync system already optimized in ${f}."
          else
            echo "${hook_block}" >> "${f}"
            echo "Optimized sync system installed into ${f}."
            updated=1
          fi
        fi
      done
      generate_sync_file
      if [[ "${updated}" -eq 1 ]]; then
        echo "✅ SUCCESS: Shell integration upgraded."
        echo "👉 Action: Run 'source ~/.bashrc' (or restart terminal) to apply permanently."
      fi
      ;;
    list)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'list'."
      list_accounts
      ;;
    save)
      [[ $# -eq 1 ]] || fail "Usage: ai ${platform:+--platform ${platform} }save <account>"
      validate_account_name "$1"
      if [[ "${platform}" == "all" ]]; then
        save_account_all "$1"
      else
        if ! platform_available "${platform}"; then
          fail "$(platform_label "${platform}") auth file not found; cannot save."
        fi
        save_account_platform "${platform}" "$1"
      fi
      ;;
    use)
      [[ $# -eq 1 ]] || fail "Usage: ai ${platform:+--platform ${platform} }use <account>"
      validate_account_name "$1"
      if [[ "${platform}" == "all" ]]; then
        use_account_all "$1"
      else
        if ! platform_available "${platform}"; then
          fail "$(platform_label "${platform}") auth file not found; cannot switch."
        fi
        use_account_platform "${platform}" "$1"
      fi
      ;;
    delete)
      [[ $# -eq 1 ]] || fail "Usage: ai delete <account>"
      validate_account_name "$1"
      delete_account "$1"
      ;;
    rename)
      [[ $# -eq 2 ]] || fail "Usage: ai rename <old-account> <new-account>"
      rename_account "$1" "$2"
      ;;
    pool-list)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'pool-list'."
      pool_list_accounts
      ;;
    pool-set)
      [[ $# -ge 1 ]] || fail "Usage: ai pool-set <account> [account...]"
      pool_set_accounts "$@"
      ;;
    pool-sync)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'pool-sync'."
      pool_sync_saved_accounts
      ;;
    pool-add)
      [[ $# -ge 1 ]] || fail "Usage: ai pool-add <account> [account...]"
      pool_add_accounts "$@"
      ;;
    pool-remove)
      [[ $# -ge 1 ]] || fail "Usage: ai pool-remove <account> [account...]"
      pool_remove_accounts "$@"
      ;;
    pool-cooldown)
      [[ $# -ge 1 && $# -le 2 ]] || fail "Usage: ai pool-cooldown <account> [seconds]"
      pool_set_manual_cooldown "$@"
      ;;
    pool-reset-cooldowns)
      pool_reset_cooldowns "$@"
      ;;
    pool-status)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'pool-status'."
      pool_status
      ;;
    codex)
      run_managed_codex "$@"
      ;;
    doctor)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'doctor'."
      doctor_check
      ;;
    test-rotation)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'test-rotation'."
      run_rotation_self_test
      ;;
    codex-wrapper-status)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'codex-wrapper-status'."
      codex_wrapper_status
      ;;
    codex-install-wrapper)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'codex-install-wrapper'."
      install_codex_wrapper
      ;;
    codex-uninstall-wrapper)
      [[ $# -eq 0 ]] || fail "Unexpected arguments for 'codex-uninstall-wrapper'."
      uninstall_codex_wrapper
      ;;
    *)
      fail "Unknown command '${command}'."
      ;;
  esac
}

main() {
  ensure_deps
  ensure_dirs
  migrate_legacy_store
  parse_args "$@"
}

main "$@"
