  [[ -f "${log_file}" ]] || return 1
  sanitize_codex_log_tail "${log_file}" | grep -Eiq \
    "You've hit your usage limit|rate limit exceeded|429 Too Many Requests|too many requests|Limits reset every|try again in [0-9]|try again at [A-Za-z0-9]"
}

sanitize_codex_log_tail() {
  local log_file="$1"
  [[ -f "${log_file}" ]] || return 0
  tail -n 800 "${log_file}" \
    | tr -d '\r\000' \
    | sed -E $'s/\x1B\\[[0-9;?]*[ -/]*[@-~]//g; s/\x1B\\][^\a]*(\a|\x1B\\\\)//g'
}

parse_rate_limit_cooldown_seconds() {
  local log_file="$1"
  local tail_text
  local line
  local absolute_line
  local absolute_text
  local parsed_absolute_epoch
  local now_epoch
  local days=0
  local hours=0
  local minutes=0
  local total=0

  tail_text="$(sanitize_codex_log_tail "${log_file}")"

  line="$(printf '%s\n' "${tail_text}" | grep -Eio 'try again in [^[:cntrl:]]+' | tail -n 1 || true)"
  if [[ -n "${line}" ]]; then
    if [[ "${line}" =~ ([0-9]+)[[:space:]]+day ]]; then
      days="${BASH_REMATCH[1]}"
    fi
    if [[ "${line}" =~ ([0-9]+)[[:space:]]+hour ]]; then
      hours="${BASH_REMATCH[1]}"
    fi
    if [[ "${line}" =~ ([0-9]+)[[:space:]]+minute ]]; then
      minutes="${BASH_REMATCH[1]}"
    fi
    total=$((days * 86400 + hours * 3600 + minutes * 60))
    if [[ "${total}" -gt 0 ]]; then
      echo "${total}"
      return 0
    fi
  fi

  absolute_line="$(printf '%s\n' "${tail_text}" | grep -Eio 'try again at [^[:cntrl:]]+' | tail -n 1 || true)"
  if [[ -n "${absolute_line}" ]]; then
    absolute_text="${absolute_line#try again at }"
    absolute_text="${absolute_text%.}"
    absolute_text="$(printf '%s' "${absolute_text}" | sed -E 's/([0-9]+)(st|nd|rd|th)/\1/g')"
    if parsed_absolute_epoch="$(date -d "${absolute_text}" +%s 2>/dev/null)"; then
      now_epoch="$(date +%s)"
      if [[ "${parsed_absolute_epoch}" =~ ^[0-9]+$ ]] && (( parsed_absolute_epoch > now_epoch )); then
        echo "$((parsed_absolute_epoch - now_epoch))"
        return 0
      fi
    fi
  fi

  if printf '%s\n' "${tail_text}" | grep -Eiq '429 Too Many Requests|too many requests'; then
    echo "${DEFAULT_HTTP_429_COOLDOWN_SECONDS}"
    return 0
  fi

  echo "${DEFAULT_RATE_LIMIT_COOLDOWN_SECONDS}"
}

run_codex_command() {
  local log_file="$1"
  shift
  local exit_code

  : > "${log_file}"

  if [[ -t 0 && -t 1 ]] && command -v "${AI_SWITCH_SCRIPT_BIN}" >/dev/null 2>&1; then
    set +e
    "${AI_SWITCH_SCRIPT_BIN}" -q -f -c "$(printf '%q ' "$@")" "${log_file}"
    exit_code=$?
    set -e
  else
    set +e
    "$@" 2>&1 | tee -a "${log_file}"
    exit_code=${PIPESTATUS[0]}
    set -e
  fi

  return "${exit_code}"
}

run_unmanaged_codex_passthrough() {
  # Multica uses `codex app-server` rather than interactive `codex`.
  # Managed rotation is not available for app-server sessions, but we can
  # still make each new server start on the healthiest ready account.
  if [[ "${1:-}" == "app-server" ]]; then
    local rotate_mode="--no-refresh"
    local limits_updated_at=""
    local limits_updated_epoch=""

    ensure_codex_limits_file
    limits_updated_at="$(jq -r '.updated_at // empty' "${CODEX_LIMITS_FILE}" 2>/dev/null || true)"
    if [[ -n "${limits_updated_at}" ]]; then
      limits_updated_epoch="$(iso_to_epoch "${limits_updated_at}" || true)"
    fi
    if [[ -z "${limits_updated_epoch}" ]] || (( $(date +%s) - limits_updated_epoch >= STATUS_STALE_SECONDS )); then
      rotate_mode="--refresh"
    fi

    rotate_best_account "${rotate_mode}" >/dev/null 2>&1 || true
  fi
  local cmd=("${AI_SWITCH_CODEX_BIN}" "$@")
  exec "${cmd[@]}"
}

has_profile_arg() {
  local args=("$@")
  local idx=0
  local arg
  while [[ "${idx}" -lt "${#args[@]}" ]]; do
    arg="${args[${idx}]}"
    case "${arg}" in
      -p|--profile)
        return 0
        ;;
      --profile=*)
        return 0
        ;;
    esac
    idx=$((idx + 1))
  done
  return 1
}

seamless_proxy_ready() {
  # Truly seamless mode uses request-level failover via local proxy.
  # We auto-enable only when proxy key is present and health endpoint responds.
  [[ -n "${CODEX_SEAMLESS_PROXY_KEY:-}" ]] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsS --max-time 1 "http://127.0.0.1:8788/health" >/dev/null 2>&1
}

run_seamless_codex_passthrough() {
  local original_args=("$@")
  local cmd=("${AI_SWITCH_CODEX_BIN}")
  if ! has_profile_arg "${original_args[@]}"; then
    cmd+=(-p seamless)
  fi
  cmd+=("${original_args[@]}")
  exec "${cmd[@]}"
}

doctor_check() {
  local issues=0
  local count

  echo "AI switch doctor:"

  if command -v ai >/dev/null 2>&1; then
    echo "  ai command: ok ($(command -v ai))"
  else
    echo "  ai command: missing"
    issues=$((issues + 1))
  fi

  if codex_wrapper_installed; then
    echo "  codex wrapper: installed"
  else
    echo "  codex wrapper: not installed"
    issues=$((issues + 1))
  fi

  if command -v bwrap >/dev/null 2>&1; then
    echo "  bubblewrap: ok ($(command -v bwrap))"
  else
    echo "  bubblewrap: missing"
    issues=$((issues + 1))
  fi

  if seamless_proxy_ready; then
    echo "  seamless proxy mode: active (codex will use -p seamless)"
  else
    echo "  seamless proxy mode: inactive"
  fi

  if [[ -f "${CODEX_AUTH_FILE}" ]]; then
    echo "  codex auth file: ok (${CODEX_AUTH_FILE})"
  else
    echo "  codex auth file: missing (${CODEX_AUTH_FILE})"
    issues=$((issues + 1))
  fi

  if [[ -f "${CODEX_HOME}/config.toml" ]] && grep -q '^cli_auth_credentials_store = "file"' "${CODEX_HOME}/config.toml"; then
    echo "  file auth mode: ok"
  else
    echo "  file auth mode: not pinned"
    issues=$((issues + 1))
  fi

  count=$(find "${STORE_DIR}" -maxdepth 1 -type f -name '*.json' 2>/dev/null | wc -l | tr -d ' ')
  echo "  saved accounts: ${count}"
  if [[ "${count}" -lt 2 ]]; then
    echo "  saved accounts status: need at least 2 for auto-rotation"
    issues=$((issues + 1))
  else
    echo "  saved accounts status: ok"
  fi

  ensure_codex_pool_file
  count=$(jq '.accounts | length' "${CODEX_POOL_FILE}")
  echo "  pool accounts: ${count}"
  if [[ "${count}" -lt 2 ]]; then
    echo "  pool status: need at least 2 accounts in pool"
    issues=$((issues + 1))
  else
    echo "  pool status: ok"
  fi

  if [[ "${issues}" -eq 0 ]]; then
    echo "Doctor result: ready"
  else
    echo "Doctor result: ${issues} issue(s) found"
    return 1
  fi
}

