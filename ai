  primary_used="$(jq -r --arg account "${account}" '.accounts[$account].primary.used_percent // empty' "${CODEX_LIMITS_FILE}")"
  primary_reset="$(jq -r --arg account "${account}" '.accounts[$account].primary.resets_at // empty' "${CODEX_LIMITS_FILE}")"
  secondary_used="$(jq -r --arg account "${account}" '.accounts[$account].secondary.used_percent // empty' "${CODEX_LIMITS_FILE}")"
  secondary_reset="$(jq -r --arg account "${account}" '.accounts[$account].secondary.resets_at // empty' "${CODEX_LIMITS_FILE}")"
  cooldown_until="$(jq -r --arg account "${account}" '.cooldowns[$account].until_epoch // 0' "${CODEX_POOL_FILE}")"

  if [[ "${cooldown_until}" =~ ^[0-9]+$ ]] && (( cooldown_until > now_epoch )); then
    cooldown_active=1
    cooldown_cell="+$(format_duration "$((cooldown_until - now_epoch))")"
    ready_badge="C"
  fi

  if [[ "${account}" == "${active_account}" ]]; then
    active_badge="A"
  fi

  state_badge_plain="${active_badge}${ready_badge}"
  line_state="${state_badge_plain}"
  if [[ "${cooldown_active}" -eq 1 ]]; then
    state_badge_view="$(colorize "33" "${line_state}")"
  else
    state_badge_view="$(colorize "32" "${line_state}")"
  fi

  p_cell="$(render_limit_compact "${primary_used}" "${primary_reset}" "${now_epoch}")"
  s_cell="$(render_limit_compact "${secondary_used}" "${secondary_reset}" "${now_epoch}")"
  plan_short="${plan_type:-na}"
  case "${source}" in
    chatgpt-app-server) source_short="app" ;;
    chatgpt-session) source_short="sess" ;;
    "") source_short="na" ;;
    *) source_short="other" ;;
  esac
  source_cell="${source_short}"

  if [[ -z "${snapshot}" ]]; then
    freshness_plain="no-data"
    freshness_view="$(colorize "33" "${freshness_plain}")"
  else
    captured_epoch="$(iso_to_epoch "${captured_at}")"
    if [[ -n "${captured_epoch}" && "${captured_epoch}" =~ ^[0-9]+$ ]]; then
      age_seconds=$((now_epoch - captured_epoch))
      freshness_plain="$(format_duration "${age_seconds}")"
      if (( age_seconds > STATUS_STALE_SECONDS )); then
        freshness_view="$(colorize "33" "${freshness_plain}")"
      else
        freshness_view="$(colorize "32" "${freshness_plain}")"
      fi
    else
      freshness_plain="unknown"
      freshness_view="$(colorize "33" "${freshness_plain}")"
    fi
  fi

  left_cell="${state_badge_view} ${account}"
  printf '%-22s  %-34s  %-34s  %-5s  %-8s  %-5s  %-8s\n' \
    "${left_cell}" \
    "${p_cell}" \
    "${s_cell}" \
    "${plan_short}" \
    "${freshness_view}" \
    "${source_cell}" \
    "${cooldown_cell}"
}

show_status() {
  local force_refresh=0
  local unsafe_refresh=0
  local arg
  local active_account
  local best_account=""
  local accounts=()
  local account
  local now_epoch
  local healthy=0
  local cooling=0
  local maybe_proxy="inactive"

  while (( $# )); do
    arg="$1"
    shift
    case "${arg}" in
      --refresh|--refresh-all)
        force_refresh=1
        ;;
      --unsafe)
        unsafe_refresh=1
        ;;
      *)
        fail "Unknown argument for 'status': ${arg}"
        ;;
    esac
  done

  ensure_codex_pool_file
  ensure_codex_limits_file
  refresh_active_account_limits_from_latest_session >/dev/null 2>&1 || true

  while IFS= read -r account; do
    [[ -z "${account}" ]] || accounts+=("${account}")
  done < <(pool_list_accounts)

  if [[ "${#accounts[@]}" -eq 0 ]]; then
    fail "Codex pool is empty. Configure with: ai pool-set <account> [account...]"
  fi

  refresh_codex_limits_cache_for_accounts "${force_refresh}" "${unsafe_refresh}" "${accounts[@]}" || true

  now_epoch="$(date +%s)"
  active_account="$(active_account_for_platform codex)"

  for account in "${accounts[@]}"; do
    if jq -e --arg account "${account}" --arg now "${now_epoch}" '(.cooldowns[$account].until_epoch // 0) > ($now | tonumber)' "${CODEX_POOL_FILE}" >/dev/null 2>&1; then
      cooling=$((cooling + 1))
    else
      healthy=$((healthy + 1))
    fi
  done

  if seamless_proxy_ready; then
    maybe_proxy="active"
  fi

  best_account="$(select_best_ready_account "${now_epoch}" "${accounts[@]}" || true)"

  local py_script
  py_script=$(cat <<'EOF'
import json
import sys
import time
import re
import shutil
import math

def colorize(code, text):
    if not sys.stdout.isatty():
        return text
    # Support multiple codes separated by semicolon
    return f"\033[{code}m{text}\033[0m"

def format_duration(seconds):
    if seconds <= 0: return "now"
    days = seconds // 86400
    hours = (seconds % 86400) // 3600
    minutes = (seconds % 3600) // 60
    secs = seconds % 60
    if days > 0: return f"{days}d{hours}h"
    if hours > 0: return f"{hours}h{minutes}m"
    if minutes > 0: return f"{minutes}m"
    return f"{secs}s"

def get_style_code(pct):
    if pct >= 90: return "31" # Red
    if pct >= 75: return "33" # Yellow
    return "32" # Green

def smooth_bar(pct, width=20):
    blocks = [" ", "▏", "▎", "▍", "▌", "▋", "▊", "▉", "█"]
    if pct < 0: pct = 0
    if pct > 100: pct = 100
    
    total_eighths = int(round((pct / 100.0) * width * 8))
    full_blocks = total_eighths // 8
    remainder = total_eighths % 8
    
    bar = "█" * full_blocks
    if full_blocks < width:
        bar += blocks[remainder]
        bar += " " * (width - full_blocks - 1)
        
    return bar

def visible_len(text):
    return len(re.sub(r'\x1b\[[0-9;]*m', '', str(text)))

def pad_right(text, width):
    v_len = visible_len(text)
    padding = max(0, width - v_len)
    return str(text) + " " * padding

def pad_left(text, width):
    v_len = visible_len(text)
    padding = max(0, width - v_len)
    return " " * padding + str(text)

def pad_center(text, width):
    v_len = visible_len(text)
    padding = max(0, width - v_len)
    left_pad = padding // 2
    right_pad = padding - left_pad
    return " " * left_pad + str(text) + " " * right_pad

def main():
    import base64
    import os
    try:
        with open(sys.argv[1]) as f:
            pool_data = json.load(f)
    except Exception:
        pool_data = {"accounts": [], "cooldowns": {}}
    
    try:
        with open(sys.argv[2]) as f:
            limits_data = json.load(f)
    except Exception:
        limits_data = {"accounts": {}}
        
    accounts = sys.argv[3].split(",") if sys.argv[3] else []
    active_account = sys.argv[4]
    best_account = sys.argv[5]
    maybe_proxy = sys.argv[6]
    stale_seconds = int(sys.argv[7])
    env_account = sys.argv[8] if len(sys.argv) > 8 else "none"
    store_dir = sys.argv[9] if len(sys.argv) > 9 else ""
    last_event = sys.argv[10] if len(sys.argv) > 10 else "None"
    total_sessions = sys.argv[11] if len(sys.argv) > 11 else "0"
    
    # Subscription info cache
    subs = {}
    for acc in accounts:
        try:
            with open(f"{store_dir}/{acc}.json") as f:
                c_data = json.load(f)
                id_t = c_data.get("tokens", {}).get("id_token")
                if id_t:
                    parts = id_t.split(".")
                    if len(parts) > 1:
                        payload = parts[1]
                        payload = payload.replace("-", "+").replace("_", "/")
                        payload += "=" * ((4 - len(payload) % 4) % 4)
                        claims = json.loads(base64.b64decode(payload))
                        def find_expiry(obj):
                            if isinstance(obj, dict):
                                if "chatgpt_subscription_active_until" in obj:
                                    return obj["chatgpt_subscription_active_until"]
                                for v in obj.values():
                                    res = find_expiry(v)
                                    if res: return res
                            return None
                        expiry = find_expiry(claims)
                        if expiry:
                            subs[acc] = expiry.split("T")[0]
        except: pass
    
    now = int(time.time())
    term_width = shutil.get_terminal_size((100, 20)).columns
    
    healthy, cooling = 0, 0
    table_rows = []
    compat_rows = []
    sum_p_used, count_p_used = 0, 0
    sum_s_used, count_s_used = 0, 0
    
    def safe_get(obj, *keys, default=None):
        for key in keys:
            if not isinstance(obj, dict): return default
            obj = obj.get(key)
            if obj is None: return default
        return obj

    bar_width = 15
    if term_width > 120: bar_width = 25
    elif term_width < 95: bar_width = 10
        
    for acc in accounts:
        is_active = (acc == active_account)
        cooldown = safe_get(pool_data, "cooldowns", acc, "until_epoch", default=0)
        cooldown_active = False
            
        if int(cooldown or 0) > now:
            cooling += 1
            cooldown_active = True
            cd_val = int(cooldown) - now
            cooldown_cell = colorize("1;31" if cd_val > 3600 else "1;33", f"⏳ {format_duration(cd_val)}")
            ready_badge = "COOL"
            st_color = "41;37" if is_active else "33"
        else:
