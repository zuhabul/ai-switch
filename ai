probe_current_codex_session_file() {
  local session_name="ai-status-$RANDOM-$$"
  local tmux_socket="ai-switch-status"
  local stamp_file
  local waited=0
  local max_wait=$((STATUS_PROBE_EXIT_WAIT_SECONDS * 2))

  stamp_file="$(new_tmp)"
  : > "${stamp_file}"

  TMUX= tmux -L "${tmux_socket}" kill-session -t "${session_name}" 2>/dev/null || true
  TMUX= tmux -L "${tmux_socket}" new-session -d -s "${session_name}" || return 1

  TMUX= tmux -L "${tmux_socket}" send-keys -t "${session_name}" "${AI_SWITCH_CODEX_BIN} --no-alt-screen" C-m
  sleep "${STATUS_PROBE_START_WAIT_SECONDS}"
  TMUX= tmux -L "${tmux_socket}" send-keys -t "${session_name}" "/status" C-m
  sleep "${STATUS_PROBE_COMMAND_WAIT_SECONDS}"
  TMUX= tmux -L "${tmux_socket}" send-keys -t "${session_name}" "/exit" C-m

  while (( waited < max_wait )); do
    if ! TMUX= tmux -L "${tmux_socket}" has-session -t "${session_name}" 2>/dev/null; then
      break
    fi
    sleep 0.5
    waited=$((waited + 1))
  done

  TMUX= tmux -L "${tmux_socket}" kill-session -t "${session_name}" 2>/dev/null || true
  detect_recent_session_file "${stamp_file}" "${PWD}" || true
}

refresh_codex_limits_cache_for_accounts() {
  local force_refresh="$1"
  local allow_when_running="$2"
  shift 2
  local accounts=("$@")
  local now_epoch
  local account
  local session_file
  local session_id
  local original_auth
  local refreshed=0
  local fallback_accounts=()

  [[ "${#accounts[@]}" -gt 0 ]] || return 0

  now_epoch="$(date +%s)"

  if app_server_probe_available; then
    for account in "${accounts[@]}"; do
      if [[ "${force_refresh}" -ne 1 ]] && ! account_needs_limits_refresh "${account}" "${now_epoch}"; then
        continue
      fi
      if refresh_account_limits_via_app_server "${account}"; then
        refreshed=$((refreshed + 1))
      else
        fallback_accounts+=("${account}")
      fi
    done
  else
    fallback_accounts=("${accounts[@]}")
  fi

  if [[ "${refreshed}" -gt 0 ]]; then
    echo "Refreshed live limits for ${refreshed} account(s) via app-server."
  fi

  [[ "${#fallback_accounts[@]}" -gt 0 ]] || return 0

  if ! command -v tmux >/dev/null 2>&1; then
    warn "tmux not found; skipping fallback status probes for ${#fallback_accounts[@]} account(s)."
    return 1
  fi

  if ! command -v "${AI_SWITCH_CODEX_BIN}" >/dev/null 2>&1; then
    warn "Codex CLI not found (${AI_SWITCH_CODEX_BIN}); skipping fallback status probes."
    return 1
  fi

  if [[ "${allow_when_running}" -ne 1 ]] && codex_process_running; then
    warn "Codex process detected; skipped fallback status probes for ${#fallback_accounts[@]} account(s)."
    return 1
  fi

  if [[ -f "${CODEX_AUTH_FILE}" ]]; then
    original_auth="$(new_tmp)"
    cp "${CODEX_AUTH_FILE}" "${original_auth}"
  else
    original_auth=""
  fi

  # Ensure the auth file is restored even if the user hits Ctrl+C during the slow probes
  trap '
    if [[ -n "${original_auth}" && -f "${original_auth}" ]]; then
      cp "${original_auth}" "${CODEX_AUTH_FILE}" 2>/dev/null || true
      chmod 600 "${CODEX_AUTH_FILE}" 2>/dev/null || true
      generate_sync_file >/dev/null 2>&1 || true
    fi
    trap - INT TERM EXIT
    exit 130
  ' INT TERM EXIT

  for account in "${fallback_accounts[@]}"; do
    if ! use_account_platform codex "${account}" >/dev/null 2>&1; then
      warn "Skipping fallback status probe for '${account}' (could not switch auth)."
      continue
    fi
    session_file="$(probe_current_codex_session_file || true)"
    if [[ -z "${session_file}" ]]; then
      warn "No fallback session data captured for '${account}'."
      continue
    fi
    session_id="$(extract_session_id_from_file "${session_file}" || true)"
    if cache_rate_limits_from_session_file "${account}" "${session_file}" "chatgpt-session" "${session_id}"; then
      refreshed=$((refreshed + 1))
    else
      warn "Fallback status probe for '${account}' did not produce rate limit metadata."
    fi
  done

  # Clear trap and restore normally
  trap - INT TERM EXIT
  if [[ -n "${original_auth}" && -f "${original_auth}" ]]; then
    cp "${original_auth}" "${CODEX_AUTH_FILE}"
    chmod 600 "${CODEX_AUTH_FILE}" || true
    generate_sync_file
  fi

  if [[ "${refreshed}" -gt 0 ]]; then
    echo "Refreshed total limits snapshots: ${refreshed} account(s)."
  fi
}

render_limit_line() {
  local label="$1"
  local used_percent="$2"
  local resets_at="$3"
  local now_epoch="$4"
  local pct
  local bar
  local style
  local pct_view
  local reset_at_view
  local reset_in

  if [[ -z "${used_percent}" || "${used_percent}" == "null" || -z "${resets_at}" || "${resets_at}" == "null" ]]; then
    echo "${label}: no data"
    return 0
  fi

  pct="$(format_percent "${used_percent}")"
  bar="$(percent_bar "${pct}" 20)"
  style="$(percent_style_code "${pct}")"
  pct_view="$(colorize "${style}" "${pct}%")"
  reset_at_view="$(format_epoch_utc "${resets_at}")"
  reset_in="$(format_duration "$((resets_at - now_epoch))")"
  echo "${label}: [${bar}] ${pct_view} used  | reset ${reset_at_view} (in ${reset_in})"
}

render_limit_compact() {
  local used_percent="$1"
  local resets_at="$2"
  local now_epoch="$3"
  local pct
