probe_rate_limits_snapshot_via_app_server_unified() {
  local unified_file="$1"
  local probe_home=""
  local probe_auth=""

  [[ -f "${unified_file}" ]] || return 1
  app_server_probe_available || return 1

  probe_home="$(new_tmp_dir)"
  probe_auth="${probe_home}/auth.json"
  build_codex_auth_from_unified "${unified_file}" > "${probe_auth}"
  chmod 600 "${probe_auth}" || true

  CODEX_HOME="${probe_home}" AI_SWITCH_CODEX_BIN="${AI_SWITCH_CODEX_BIN}" python3 - <<'PY'
import json
import os
import select
import subprocess
import sys
import time

codex_bin = os.environ.get("AI_SWITCH_CODEX_BIN", "codex")
request_id = "rate-limits-read-1"

proc = subprocess.Popen(
    [codex_bin, "app-server", "--listen", "stdio://"],
    stdin=subprocess.PIPE,
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    text=True,
    bufsize=1,
)

def send(msg):
    proc.stdin.write(json.dumps(msg, separators=(",", ":")) + "\n")
    proc.stdin.flush()

def fail():
    try:
        proc.terminate()
    except Exception:
        pass
    try:
        proc.wait(timeout=1.5)
    except Exception:
        try:
            proc.kill()
        except Exception:
            pass
    raise SystemExit(1)

try:
    send(
        {
            "id": "init-1",
            "method": "initialize",
            "params": {
                "clientInfo": {"name": "ai-switch", "version": "0.1.0"},
                "capabilities": {"experimentalApi": False},
            },
        }
    )
    send({"method": "initialized", "params": {}})
    send({"id": request_id, "method": "account/rateLimits/read", "params": None})

    deadline = time.time() + 12
    while time.time() < deadline:
        ready, _, _ = select.select([proc.stdout, proc.stderr], [], [], 0.5)
        for stream in ready:
            line = stream.readline()
            if not line:
                continue
            if stream is proc.stderr:
                continue
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line)
            except Exception:
                continue
            if msg.get("id") != request_id:
                continue
            result = msg.get("result")
            if not isinstance(result, dict):
                fail()
            by_limit = result.get("rateLimitsByLimitId")
            snapshot = None
            if isinstance(by_limit, dict):
                snapshot = by_limit.get("codex")
                if snapshot is None and len(by_limit) == 1:
                    snapshot = next(iter(by_limit.values()))
            if snapshot is None:
                snapshot = result.get("rateLimits")
            if not isinstance(snapshot, dict):
                fail()
            print(json.dumps(snapshot, separators=(",", ":")))
            try:
                proc.terminate()
            except Exception:
                pass
            raise SystemExit(0)
    fail()
except SystemExit:
    raise
except Exception:
    fail()
PY
}

app_server_snapshot_to_event_json() {
  local snapshot_json="$1"
  jq -nc --arg captured_at "$(now_utc)" --argjson snapshot "${snapshot_json}" '
    {
      captured_at: $captured_at,
      rate_limits: {
        limit_id: ($snapshot.limitId // null),
        limit_name: ($snapshot.limitName // null),
        plan_type: ($snapshot.planType // null),
        primary: (
          if ($snapshot.primary | type) == "object" then
            {
              used_percent: ($snapshot.primary.usedPercent // null),
              window_minutes: ($snapshot.primary.windowDurationMins // null),
              resets_at: ($snapshot.primary.resetsAt // null)
            }
          else
            null
          end
        ),
        secondary: (
          if ($snapshot.secondary | type) == "object" then
            {
              used_percent: ($snapshot.secondary.usedPercent // null),
              window_minutes: ($snapshot.secondary.windowDurationMins // null),
              resets_at: ($snapshot.secondary.resetsAt // null)
            }
          else
            null
          end
        ),
        credits: (
          if ($snapshot.credits | type) == "object" then
            {
              has_credits: ($snapshot.credits.hasCredits // null),
              unlimited: ($snapshot.credits.unlimited // null),
              balance: ($snapshot.credits.balance // null)
            }
          else
